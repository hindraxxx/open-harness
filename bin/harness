    html_path.parent.mkdir(parents=True, exist_ok=True)
    html_path.write_text(document)
    return html_path


def render_artifact_html(session_id: str) -> Path | None:
    md_path = artifact_path(session_id)
    if not md_path.exists():
        return None
    metadata, body = parse_frontmatter(read_text(md_path))
    title = metadata.get("session_id") or session_id
    status = metadata.get("status", "unknown")
    updated_at = display_metadata_value("updated_at", metadata.get("updated_at", ""))
    meta_rows = "".join(
        f"<tr><th>{html.escape(key)}</th><td>{html.escape(display_metadata_value(key, value))}</td></tr>"
        for key, value in metadata.items()
    )
    document = f"""<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Harness Artifact: {html.escape(title)}</title>
<style>
:root {{
  color-scheme: light;
  font-family: "Avenir Next", "Segoe UI", -apple-system, BlinkMacSystemFont, sans-serif;
  --ink: #17202a;
  --muted: #637083;
  --line: #d9e0e8;
  --paper: #ffffff;
  --wash: #f4f6f8;
  --accent: #176d73;
  --accent-soft: #dff1f1;
  --code: #18212f;
}}
* {{ box-sizing: border-box; }}
body {{
  margin: 0;
  background:
    linear-gradient(180deg, rgba(223, 241, 241, 0.65), rgba(244, 246, 248, 0) 360px),
    var(--wash);
  color: var(--ink);
  line-height: 1.55;
