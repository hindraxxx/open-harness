def proof_dir(session_id: str) -> Path:
    return sessions_dir() / session_id / "proof"


def annotations_path(session_id: str) -> Path:
    return sessions_dir() / session_id / "annotations.json"


def load_annotations(session_id: str) -> list[dict]:
    path = annotations_path(session_id)
    if not path.exists():
        return []
    try:
        data = json.loads(path.read_text())
    except (json.JSONDecodeError, OSError):
        return []
    return data if isinstance(data, list) else []


def save_annotations(session_id: str, annotations: list[dict]) -> None:
    path = annotations_path(session_id)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(annotations, indent=2) + "\n")


def add_annotation(session_id: str, payload: dict) -> dict:
    quote = str(payload.get("quote", "")).strip()
    comment = str(payload.get("comment", "")).strip()
    if not quote or not comment:
        raise ValueError("annotation requires non-empty quote and comment")
    annotation = {
        "id": uuid.uuid4().hex,
        "section": str(payload.get("section", "")).strip(),
        "quote": quote,
        "prefix": str(payload.get("prefix", "")),
        "suffix": str(payload.get("suffix", "")),
        "comment": comment,
        "status": "open",
        "created_at": now(),
        "addressed_at": "",
    }
    annotations = load_annotations(session_id)
    annotations.append(annotation)
    save_annotations(session_id, annotations)
    return annotation


def update_annotation(session_id: str, annotation_id: str, changes: dict) -> dict | None:
    annotations = load_annotations(session_id)
    updated = None
    for annotation in annotations:
        if annotation.get("id") == annotation_id:
            if "comment" in changes:
                comment = str(changes["comment"]).strip()
                if comment:
                    annotation["comment"] = comment
            if changes.get("status") in {"open", "addressed"}:
                annotation["status"] = changes["status"]
                annotation["addressed_at"] = now() if changes["status"] == "addressed" else ""
            updated = annotation
            break
    if updated is not None:
        save_annotations(session_id, annotations)
    return updated


def delete_annotation(session_id: str, annotation_id: str) -> bool:
    annotations = load_annotations(session_id)
    remaining = [a for a in annotations if a.get("id") != annotation_id]
    if len(remaining) == len(annotations):
        return False
    save_annotations(session_id, remaining)
    return True


def agents_bootstrap_path() -> Path:
    sample = root() / "AGENTS_SAMPLE.md"
    if sample.exists():
        return sample
    return root() / "AGENTS.md"


def db_path() -> Path:
    return harness_dir() / "harness.db"


def version_path() -> Path:
    return harness_dir() / "version"


def now() -> str:
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat()


def slugify(text: str) -> str:
    # Strip any inline HTML then decode entities (e.g. &amp;) so the slug is the
    # same whether it is derived from rendered heading HTML or raw markdown.
    normalized = re.sub(r"<[^>]+>", "", text)
    normalized = html.unescape(normalized)
    normalized = re.sub(r"[^a-zA-Z0-9]+", "-", normalized).strip("-").lower()
    return normalized or "section"


def date_prefixed_session_id(title: str, created_at: str) -> str:
    if re.match(r"^\d{8}_", title):
        return title
    created = dt.datetime.fromisoformat(created_at.replace("Z", "+00:00"))
    return f"{created:%Y%m%d}_{title}"


JAKARTA_TZ = dt.timezone(dt.timedelta(hours=7), "GMT+7")


def format_display_timestamp(value: str) -> str:
    raw = value.strip()
    if not raw:
        return raw
    try:
        parsed = dt.datetime.fromisoformat(raw.replace("Z", "+00:00"))
    except ValueError:
        return value
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=dt.timezone.utc)
    local = parsed.astimezone(JAKARTA_TZ)
    return f"{local:%A, %d %B %Y %H:%M:%S} GMT+7"


def display_metadata_value(key: str, value: str) -> str:
    if key.endswith("_at"):
        return format_display_timestamp(value)
    return value


def die(message: str, code: int = 1) -> None:
    print(f"error: {message}", file=sys.stderr)
    raise SystemExit(code)


def read_text(path: Path) -> str:
    try:
        return path.read_text()
    except FileNotFoundError:
        die(f"missing file: {path}")


def write_new(path: Path, content: str) -> bool:
    if path.exists():
        return False
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)
    return True


def write_harness_version() -> None:
    harness_dir().mkdir(exist_ok=True)
    version_path().write_text(f"{HARNESS_VERSION}\n")


def read_harness_version() -> str | None:
    try:
        return version_path().read_text().strip()
    except FileNotFoundError:
        return None


def version_parts(version: str) -> tuple[int | str, ...]:
    parts: list[int | str] = []
    for part in re.split(r"[.-]", version):
        if part.isdigit():
            parts.append(int(part))
        elif part:
            parts.append(part)
    return tuple(parts)


def target_guardrails_outdated() -> bool:
    if not harness_dir().exists():
        return False
    current = read_harness_version()
    if not current:
        return True
    return version_parts(current) < version_parts(HARNESS_VERSION)


def warn_if_guardrails_outdated() -> None:
    if target_guardrails_outdated():
        print("warning: target guardrails are outdated; run harness update", file=sys.stderr)


def version_label(version: str | None) -> str:
    return version if version else "none"


def print_harness_version_change(previous: str | None) -> None:
    print(f"harness version: {version_label(previous)} -> {HARNESS_VERSION}")


def ensure_gitignore() -> None:
    path = root() / ".gitignore"
    required = [".env", ".harness/harness.db"]
    if path.exists():
        lines = path.read_text().splitlines()
        missing = [line for line in required if line not in lines]
        if missing:
            with path.open("a") as fh:
                if lines and lines[-1] != "":
                    fh.write("\n")
                for line in missing:
                    fh.write(f"{line}\n")
    else:
        path.write_text("".join(f"{line}\n" for line in required))


def ensure_claude_symlink() -> None:
    # Point CLAUDE.md at the agent bootstrap file (AGENTS.md in a target
    # project, AGENTS_SAMPLE.md in this repo) so Claude Code and AGENTS.md
    # readers share one source of truth. Idempotent; never clobbers a real file.
    bootstrap = agents_bootstrap_path()
    link = root() / "CLAUDE.md"
    if link.name == bootstrap.name:
        return
    target_name = bootstrap.name
    if link.is_symlink():
        if os.readlink(link) != target_name:
            link.unlink()
            link.symlink_to(target_name)
        return
    if link.exists():
        return
    link.symlink_to(target_name)


def default_approval_name(explicit: str | None) -> str:
    if explicit:
        return explicit
    result = subprocess.run(
        ["whoami"],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    name = result.stdout.strip() if result.returncode == 0 else ""
    if name:
        return name
    return os.environ.get("USER") or os.environ.get("USERNAME") or "unknown"


