    html_path = artifact_html_path(session_id)
    html_path.write_text(document)
    return html_path


def update_artifact_meta(session_id: str, updates: dict[str, str]) -> None:
    path = artifact_path(session_id)
    data, body = parse_frontmatter(read_text(path))
    data.update(updates)
    data["updated_at"] = now()
    path.write_text(dump_frontmatter(data, body))
    render_artifact_html(session_id)


def recovery_attempts(session_id: str) -> int:
    raw = artifact_meta(session_id).get("recovery_attempts", "0")
    try:
        value = int(raw)
    except ValueError:
        return 0
    return max(value, 0)


def set_recovery_attempts(session_id: str, attempts: int) -> None:
    update_artifact_meta(session_id, {"recovery_attempts": str(max(attempts, 0))})


def db() -> sqlite3.Connection:
    path = db_path()
    if not path.exists():
        die(f"missing SQLite state store: {path}; run `harness init` or `harness migrate-sqlite`")
    try:
        conn = sqlite3.connect(path)
    except sqlite3.Error as exc:
        die(f"cannot open SQLite state store {path}: {exc}")
    conn.row_factory = sqlite3.Row
    return conn


def init_db() -> None:
    harness_dir().mkdir(exist_ok=True)
    with sqlite3.connect(db_path()) as conn:
        conn.executescript(
            """
            CREATE TABLE IF NOT EXISTS sessions (
              session_id TEXT PRIMARY KEY,
              state TEXT NOT NULL,
              artifact_path TEXT NOT NULL,
              created_at TEXT NOT NULL,
              updated_at TEXT NOT NULL
            );
            CREATE TABLE IF NOT EXISTS transitions (
              id INTEGER PRIMARY KEY AUTOINCREMENT,
              session_id TEXT NOT NULL,
              from_state TEXT NOT NULL,
              to_state TEXT NOT NULL,
              created_at TEXT NOT NULL,
              result TEXT NOT NULL,
              reason TEXT DEFAULT ''
            );
            CREATE TABLE IF NOT EXISTS approvals (
              id INTEGER PRIMARY KEY AUTOINCREMENT,
              session_id TEXT NOT NULL,
              approval_type TEXT NOT NULL,
              approver TEXT NOT NULL,
              approval_hash TEXT DEFAULT '',
              created_at TEXT NOT NULL
            );
            CREATE TABLE IF NOT EXISTS review_passes (
              id INTEGER PRIMARY KEY AUTOINCREMENT,
              session_id TEXT NOT NULL,
              content TEXT NOT NULL,
              created_at TEXT NOT NULL
            );
            CREATE TABLE IF NOT EXISTS required_fixes (
              id INTEGER PRIMARY KEY AUTOINCREMENT,
              session_id TEXT NOT NULL,
              description TEXT NOT NULL,
              resolved INTEGER NOT NULL DEFAULT 0,
              created_at TEXT NOT NULL,
              resolved_at TEXT DEFAULT ''
            );
            CREATE TABLE IF NOT EXISTS proofs (
              id INTEGER PRIMARY KEY AUTOINCREMENT,
              session_id TEXT NOT NULL,
              path TEXT NOT NULL,
              proof_type TEXT DEFAULT '',
              created_at TEXT NOT NULL
            );
            """
        )


def db_session(session_id: str) -> sqlite3.Row | None:
    with db() as conn:
        return conn.execute("SELECT * FROM sessions WHERE session_id = ?", (session_id,)).fetchone()


def insert_session(session_id: str, state: str, created_at: str) -> None:
    with db() as conn:
        conn.execute(
            "INSERT INTO sessions(session_id, state, artifact_path, created_at, updated_at) VALUES (?, ?, ?, ?, ?)",
            (session_id, state, str(artifact_path(session_id)), created_at, created_at),
        )


def set_session_state(session_id: str, state: str) -> None:
    timestamp = now()
    with db() as conn:
        conn.execute(
            "UPDATE sessions SET state = ?, updated_at = ? WHERE session_id = ?",
            (state, timestamp, session_id),
        )
    update_artifact_meta(session_id, {"status": state})


def record_transition(session_id: str, from_state: str, to_state: str, result: str, reason: str = "") -> None:
    with db() as conn:
        conn.execute(
            "INSERT INTO transitions(session_id, from_state, to_state, created_at, result, reason) VALUES (?, ?, ?, ?, ?, ?)",
            (session_id, from_state, to_state, now(), result, reason),
        )


def latest_approval(session_id: str, approval_type: str) -> sqlite3.Row | None:
    with db() as conn:
        return conn.execute(
            """
            SELECT * FROM approvals
            WHERE session_id = ? AND approval_type = ?
            ORDER BY id DESC
            LIMIT 1
            """,
            (session_id, approval_type),
        ).fetchone()


def insert_approval(session_id: str, approval_type: str, approver: str, approval_hash: str = "") -> None:
    with db() as conn:
        conn.execute(
            "INSERT INTO approvals(session_id, approval_type, approver, approval_hash, created_at) VALUES (?, ?, ?, ?, ?)",
            (session_id, approval_type, approver, approval_hash, now()),
        )


def clear_quality_approval(session_id: str) -> None:
    path = artifact_path(session_id)
    data, body = parse_frontmatter(read_text(path))
    data.update(
        {
            "quality_approved": "false",
            "quality_approved_by": "",
            "quality_approved_at": "",
            "updated_at": now(),
        }
    )
    body = replace_section(body, "Final Approval", "TBD")
    path.write_text(dump_frontmatter(data, body))
    with db() as conn:
        conn.execute(
            "DELETE FROM approvals WHERE session_id = ? AND approval_type = ?",
            (session_id, "quality"),
        )


def clear_review_approval(session_id: str) -> None:
    path = artifact_path(session_id)
    data, body = parse_frontmatter(read_text(path))
    data.update(
        {
            "review_approved": "false",
            "review_approved_by": "",
            "review_approved_at": "",
            "updated_at": now(),
        }
    )
    body = replace_subsection(body, "Review", "Human Review", "TBD")
    path.write_text(dump_frontmatter(data, body))
    with db() as conn:
        conn.execute(
            "DELETE FROM approvals WHERE session_id = ? AND approval_type = ?",
            (session_id, "review"),
        )


def clear_quality_evidence(session_id: str) -> None:
    path = artifact_path(session_id)
    data, body = parse_frontmatter(read_text(path))
    body = replace_subsection(body, "Quality Check", "Commands Run", "TBD")
    body = replace_subsection(body, "Quality Check", "Proof", "- [ ] TBD")
    body = replace_subsection(body, "Quality Check", "Manual Validation", "TBD")
    data["updated_at"] = now()
    path.write_text(dump_frontmatter(data, body))
    with db() as conn:
        conn.execute("DELETE FROM proofs WHERE session_id = ?", (session_id,))


def insert_review_pass(session_id: str, content: str) -> None:
    with db() as conn:
        conn.execute(
            "INSERT INTO review_passes(session_id, content, created_at) VALUES (?, ?, ?)",
            (session_id, content, now()),
        )


def insert_required_fix(session_id: str, description: str) -> None:
    with db() as conn:
        conn.execute(
            "INSERT INTO required_fixes(session_id, description, resolved, created_at) VALUES (?, ?, 0, ?)",
            (session_id, description, now()),
        )


def sync_required_fixes_from_artifact(session_id: str, text: str) -> None:
    review = section(text, "Review")
    required_fixes = subsection(review, "Required Fixes")
    with db() as conn:
        rows = conn.execute(
            "SELECT id, description FROM required_fixes WHERE session_id = ? AND resolved = 0",
            (session_id,),
        ).fetchall()
        for row in rows:
            pattern = rf"^-\s*\[[xX]\]\s+{re.escape(row['description'])}\s*$"
            if re.search(pattern, required_fixes, re.MULTILINE):
                conn.execute(
                    "UPDATE required_fixes SET resolved = 1, resolved_at = ? WHERE id = ?",
                    (now(), row["id"]),
                )


def unresolved_required_fixes(session_id: str) -> list[str]:
    with db() as conn:
        rows = conn.execute(
            "SELECT description FROM required_fixes WHERE session_id = ? AND resolved = 0 ORDER BY id",
            (session_id,),
        ).fetchall()
    return [row["description"] for row in rows]


def insert_proof(session_id: str, path: Path, proof_type: str = "") -> None:
    with db() as conn:
        conn.execute(
            "INSERT INTO proofs(session_id, path, proof_type, created_at) VALUES (?, ?, ?, ?)",
            (session_id, str(path), proof_type, now()),
        )


def migrate_sqlite() -> int:
    init_db()
    migrated = 0
    for path in sessions_dir().glob("*/artifact.md"):
        session_id = path.parent.name
        if db_session(session_id):
            continue
        data, _ = parse_frontmatter(read_text(path))
        state = data.get("status", "start")
        if state not in STATES:
            state = "start"
        created = data.get("created_at") or now()
        insert_session(session_id, state, created)
        if data.get("planning_approved") == "true":
            insert_approval(session_id, "planning", data.get("planning_approved_by", ""), data.get("planning_approved_hash", ""))
        if data.get("review_approved") == "true":
            insert_approval(session_id, "review", data.get("review_approved_by", ""), "")
        if data.get("quality_approved") == "true":
            insert_approval(session_id, "quality", data.get("quality_approved_by", ""), quality_snapshot(read_text(path)))
        migrated += 1
    return migrated


def artifact_meta(session_id: str) -> dict[str, str]:
    data, _ = parse_frontmatter(read_text(artifact_path(session_id)))
    return data


def current_state(session_id: str) -> str:
    row = db_session(session_id)
    if not row:
        if artifact_path(session_id).exists():
            migrate_sqlite()
            row = db_session(session_id)
    if not row:
        die(f"session not found in SQLite state store: {session_id}; run `harness migrate-sqlite`")
    state = row["state"]
    if state not in STATES:
        die(f"invalid state in SQLite state store for {session_id}: {state}")
    return state


def artifact_recovery_attempts(path: Path) -> str:
    if not path.exists():
        return "?"
    data, _ = parse_frontmatter(read_text(path))
    raw = data.get("recovery_attempts", "0")
    try:
        return str(max(int(raw), 0))
    except ValueError:
        return "0"


def one_line_summary(value: str, limit: int = 120) -> str:
    summary = " ".join(value.strip().split())
    if len(summary) <= limit:
        return summary
    return summary[: limit - 3].rstrip() + "..."


def section(text: str, heading: str) -> str:
    pattern = re.compile(rf"^## {re.escape(heading)}\s*$", re.MULTILINE)
    match = pattern.search(text)
    if not match:
        return ""
    next_match = re.search(r"^## ", text[match.end() :], re.MULTILINE)
    if not next_match:
        return text[match.end() :].strip()
    return text[match.end() : match.end() + next_match.start()].strip()


def subsection(text: str, heading: str) -> str:
    pattern = re.compile(rf"^### {re.escape(heading)}\s*$", re.MULTILINE)
    match = pattern.search(text)
    if not match:
        return ""
    next_match = re.search(r"^### |^## ", text[match.end() :], re.MULTILINE)
    if not next_match:
        return text[match.end() :].strip()
    return text[match.end() : match.end() + next_match.start()].strip()


def has_real_content(value: str) -> bool:
    cleaned = value.strip()
    if not cleaned:
        return False
    if cleaned == "TBD":
        return False
    lines = [line.strip() for line in cleaned.splitlines() if line.strip()]
    if lines and all(re.match(r"^-+\s*\[[ xX]\]\s*TBD$", line) for line in lines):
        return False
    return True


def has_implementation_sketch(value: str) -> bool:
    sketch = subsection(value, "Implementation Sketch")
    if has_real_content(sketch):
        return True
    without_mermaid = re.sub(
        r"(```|~~~)mermaid\s+.*?\1",
        "",
        value,
        flags=re.IGNORECASE | re.DOTALL,
    )
    lowered = without_mermaid.lower()
    sketch_markers = [
        "pseudocode:",
        "pseudo-code:",
        "code shape:",
        "sample function",
        "sample code",
    ]
    return "```" in without_mermaid or any(marker in lowered for marker in sketch_markers)


def has_guidance_subsection(value: str, heading: str) -> bool:
    content = subsection(value, heading)
    if not has_real_content(content):
        return False
    without_placeholders = "\n".join(
        line for line in content.splitlines() if line.strip() != "TBD"
    )
    return has_real_content(without_placeholders)


def has_mermaid_sequence_subsection(value: str, heading: str) -> bool:
    content = subsection(value, heading)
    if not has_real_content(content):
        return False
    return bool(
        re.search(
            r"(```|~~~)mermaid\s+.*?\bsequenceDiagram\b.*?\1",
            content,
            re.IGNORECASE | re.DOTALL,
        )
    )


def has_old_flow_subsection(value: str) -> bool:
    # A greenhorn change with no predecessor flow may leave Old Flow without a
    # diagram, as long as the subsection explains why. Accept either a Mermaid
    # sequence diagram or a non-empty explanatory note; reject a blank subsection.
    if has_mermaid_sequence_subsection(value, "Old Flow"):
        return True
    return has_real_content(subsection(value, "Old Flow"))


def has_real_implementation_guidance(value: str) -> bool:
    without_mermaid = re.sub(
        r"(```|~~~)mermaid\s+.*?\1",
        "",
        value,
        flags=re.IGNORECASE | re.DOTALL,
    )
    without_headings = re.sub(r"^### .*$", "", without_mermaid, flags=re.MULTILINE)
    without_placeholders = "\n".join(
        line for line in without_headings.splitlines() if line.strip() != "TBD"
    )
    return has_real_content(without_placeholders)


def has_checked_item(value: str) -> bool:
    return bool(re.search(r"^-\s*\[[xX]\]\s+.+", value, re.MULTILINE))


def has_unchecked_item(value: str) -> bool:
    return bool(re.search(r"^-\s*\[ \]\s+.+", value, re.MULTILINE))


def has_any_checklist_item(value: str) -> bool:
    return bool(re.search(r"^-\s*\[[ xX]\]\s+.+", value, re.MULTILINE))


def checklist_complete(value: str) -> bool:
    return has_any_checklist_item(value) and not has_unchecked_item(value)


def checked_markdown_links(value: str) -> list[str]:
    return re.findall(r"^-\s*\[[xX]\]\s+\[[^\]]+\]\(([^)]+)\)", value, re.MULTILINE)


def proof_links_resolve(session_id: str, value: str) -> bool:
    links = checked_markdown_links(value)
    if not links:
        return False
    base = artifact_path(session_id).parent
    allowed = proof_dir(session_id).resolve()
    for link in links:
        target = (base / link).resolve()
        try:
            target.relative_to(allowed)
        except ValueError:
            return False
        if not target.exists() or not target.is_file():
            return False
    return True


def proof_link_targets(session_id: str, value: str) -> list[Path]:
    targets = []
    base = artifact_path(session_id).parent
    allowed = proof_dir(session_id).resolve()
    for link in checked_markdown_links(value):
        target = (base / link).resolve()
        try:
            target.relative_to(allowed)
        except ValueError:
            continue
        if target.exists() and target.is_file():
            targets.append(target)
    return targets


def has_screenshot_proof(session_id: str, value: str) -> bool:
    screenshot_exts = {".png", ".jpg", ".jpeg", ".webp", ".gif", ".pdf"}
    for target in proof_link_targets(session_id, value):
        name = target.name.lower()
        if target.suffix.lower() in screenshot_exts or "screenshot" in name:
            return True
    return False


def validation_plan_for_planning_snapshot(text: str) -> str:
    return re.sub(r"^-\s*\[[xX]\]\s+", "- [ ] ", section(text, "Validation Plan"), flags=re.MULTILINE)


def planning_snapshot(text: str) -> str:
    parts = [
        "Requirement Summary",
        section(text, "Requirement Summary"),
        "Acceptance Criteria",
        section(text, "Acceptance Criteria"),
        "Validation Plan",
        validation_plan_for_planning_snapshot(text),
        "Implementation Guidance",
        section(text, "Implementation Guidance"),
    ]
    normalized = "\n".join(part.strip() for part in parts)
    normalized = re.sub(r"[ \t]+", " ", normalized)
    normalized = re.sub(r"\n{3,}", "\n\n", normalized).strip()
    return hashlib.sha256(normalized.encode("utf-8")).hexdigest()


def quality_snapshot(text: str) -> str:
    parts = [
        "Validation Plan",
        section(text, "Validation Plan"),
        "Quality Check",
        section(text, "Quality Check"),
    ]
    normalized = "\n".join(part.strip() for part in parts)
    normalized = re.sub(r"[ \t]+", " ", normalized)
    normalized = re.sub(r"\n{3,}", "\n\n", normalized).strip()
    return hashlib.sha256(normalized.encode("utf-8")).hexdigest()


def check_section_items(text: str, heading: str) -> str:
    match = re.search(rf"^## {re.escape(heading)}\s*$", text, re.MULTILINE)
    if not match:
        return text
    content_start = match.end()
    remainder = text[content_start:]
    next_heading = re.search(r"^## ", remainder, re.MULTILINE)
    content_end = content_start + (next_heading.start() if next_heading else len(remainder))
    content = text[content_start:content_end]
    checked = re.sub(r"^-\s*\[ \]\s+", "- [x] ", content, flags=re.MULTILINE)
    return text[:content_start] + checked + text[content_end:]


def replace_subsection(text: str, section_heading: str, subsection_heading: str, content: str) -> str:
    section_match = re.search(rf"^## {re.escape(section_heading)}[ \t]*$", text, re.MULTILINE)
    if not section_match:
        return text.rstrip() + f"\n\n## {section_heading}\n\n### {subsection_heading}\n\n{content.strip()}\n"
    subsection_match = re.search(
        rf"^### {re.escape(subsection_heading)}[ \t]*$",
        text[section_match.end() :],
        re.MULTILINE,
    )
    if not subsection_match:
        insert_at = section_match.end()
        return text[:insert_at] + f"\n\n### {subsection_heading}\n\n{content.strip()}\n" + text[insert_at:]
    content_start = section_match.end() + subsection_match.end()
    remainder = text[content_start:]
    next_heading = re.search(r"^### |^## ", remainder, re.MULTILINE)
    content_end = content_start + (next_heading.start() if next_heading else len(remainder))
    replacement = f"\n\n{content.strip()}\n\n"
    return text[:content_start] + replacement + text[content_end:]


def replace_section(text: str, heading: str, content: str) -> str:
    match = re.search(rf"^## {re.escape(heading)}[ \t]*$", text, re.MULTILINE)
    if not match:
        return text.rstrip() + f"\n\n## {heading}\n\n{content.strip()}\n"
    content_start = match.end()
    remainder = text[content_start:]
    next_heading = re.search(r"^## ", remainder, re.MULTILINE)
    content_end = content_start + (next_heading.start() if next_heading else len(remainder))
    return text[:content_start] + f"\n\n{content.strip()}\n\n" + text[content_end:]


def append_subsection(text: str, section_heading: str, subsection_heading: str, content: str) -> str:
    existing = subsection(section(text, section_heading), subsection_heading)
    if has_real_content(existing) and existing.strip() != "None.":
        new_content = existing.rstrip() + f"\n\n{content.strip()}"
    else:
        new_content = content.strip()
    return replace_subsection(text, section_heading, subsection_heading, new_content)


def quality_evidence_present(text: str) -> bool:
    quality = section(text, "Quality Check")
    if not quality:
        return False
    commands = subsection(quality, "Commands Run")
    proof = subsection(quality, "Proof")
    manual = subsection(quality, "Manual Validation")
    return (
        has_real_content(commands)
        or has_checked_item(proof)
        or bool(checked_markdown_links(proof))
        or has_real_content(manual)
    )


def next_action_for_state(state: str) -> str:
    return {
        "start": "transition to planning",
        "planning": "fill planning artifact sections, get human planning approval, then transition to implementation",
        "implementation": "finish code, check every implementation checklist item, then transition to review; do not run quality validation here",
        "needs-fix": "fix required items, check implementation checklist items, then transition to implementation",
        "review": "record AI/human review, get human review approval, then transition to quality-check",
        "quality-check": "execute validation plan, attach proof files, then transition to approval",
        "approval": "wait for human quality approval, run approve-quality, then transition to done",
        "blocked": "record human decision, then transition to planning/implementation/quality-check/approval/done",
        "done": "no next action",
    }.get(state, "unknown")


def next_followup_commands(session_id: str, state: str) -> list[str]:
    return {
        "start": [
            f"harness validate {session_id}",
            f"harness transition {session_id} planning",
        ],
        "planning": [
            f"harness validate {session_id}",
            f"harness approve-planning {session_id}",
            f"harness transition {session_id} implementation",
        ],
        "implementation": [
            f"harness preflight-edit {session_id}",
            f"harness validate {session_id}",
            f"harness transition {session_id} review",
        ],
        "needs-fix": [
            f"harness preflight-edit {session_id}",
            f"harness validate {session_id}",
            f"harness transition {session_id} implementation",
        ],
        "review": [
            f"harness record-review {session_id} --ai <summary>",
            f"harness validate {session_id}",
            f"harness approve-review {session_id}",
            f"harness transition {session_id} quality-check",
        ],
        "quality-check": [
            f"harness attach-proof {session_id} <file>",
            f"harness validate {session_id}",
            f"harness transition {session_id} approval",
        ],
        "approval": [
            f"harness validate {session_id}",
            f"harness approve-quality {session_id}",
            f"harness transition {session_id} done",
        ],
        "blocked": [
            f"harness history {session_id}",
            f"harness transition {session_id} <state>",
        ],
        "done": [],
    }.get(state, [])


def quality_gate_mode() -> str:
    default = "auto"
    path = harness_dir() / "harness.yml"
    if not path.exists():
        return default
    lines = path.read_text().splitlines()
    in_gate = False
    for line in lines:
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            continue
        if stripped == "quality_gate:":
            in_gate = True
            continue
        if in_gate:
            if not line.startswith("  "):
                break
            if ":" not in stripped:
                continue
            key, value = stripped.split(":", 1)
            if key == "required_proof":
                mode = value.strip().strip('"').strip("'").lower()
                if mode in {"auto", "backend", "frontend", "both", "manual"}:
                    return mode
    return default


def project_map_text() -> str:
    path = project_map_dir()
    if not path.exists():
        return ""
    chunks = []
    for name in ["overview.md", "architecture.md", "conventions.md", "validation.md", "risks.md"]:
        file_path = path / name
        if file_path.exists():
            chunks.append(file_path.read_text(errors="ignore"))
    return "\n".join(chunks)


def inferred_quality_gate(text: str) -> str:
    mode = quality_gate_mode()
    if mode != "auto":
        return mode
    haystack = f"{section(text, 'Validation Plan')}\n{project_map_text()}".lower()
    backend_terms = ["backend", "api", "endpoint", "curl", "http", "request", "response", "controller"]
    frontend_terms = ["frontend", "fe", "ui", "browser", "playwright", "screenshot", "view", "component", "page"]
    is_backend = any(term in haystack for term in backend_terms)
    is_frontend = any(term in haystack for term in frontend_terms)
    if is_backend and is_frontend:
        return "both"
    if is_backend:
        return "backend"
    if is_frontend:
        return "frontend"
    return "manual"


def quality_gate_missing(session_id: str, text: str) -> list[str]:
    mode = inferred_quality_gate(text)
    if mode == "manual":
        return []
    quality = section(text, "Quality Check")
    commands = subsection(quality, "Commands Run")
    proof = subsection(quality, "Proof")
    manual = subsection(quality, "Manual Validation")
    combined = f"{commands}\n{manual}".lower()
    missing = []
    if mode in {"backend", "both"}:
        if "curl" not in commands.lower():
            missing.append("Backend proof requires a curl command under Quality Check Commands Run")
        if not re.search(r"\b(sample response|response|http/[0-9.]+|status[: ]+\d{3}|status code[: ]+\d{3})\b", combined):
            missing.append("Backend proof requires a sample response or HTTP status/result")
    if mode in {"frontend", "both"}:
        if not has_screenshot_proof(session_id, proof):
            missing.append("Frontend proof requires screenshot proof attached under proof/")
        if not re.search(r"\b(view|screen|page|ui|browser|playwright|screenshot)\b", combined):
            missing.append("Frontend proof requires view validation notes or browser validation result")
    return missing


def validate_requirements(
    session_id: str,
    target: str | None = None,
    require_quality_execution: bool = True,
) -> list[str]:
    path = artifact_path(session_id)
    text = read_text(path)
    state = current_state(session_id)
    check_state = target or state
    missing = []

    if state not in {"quality-check", "approval", "done"} and quality_evidence_present(text):
        missing.append("Quality Check evidence exists before quality-check state; transition through review before validation")

    if check_state in {"planning", "implementation", "review", "quality-check", "approval", "done"}:
        acceptance_criteria = section(text, "Acceptance Criteria")
        validation_plan = section(text, "Validation Plan")
        implementation_guidance = section(text, "Implementation Guidance")
        implementation_checklist = section(text, "Implementation Checklist")
        if not has_real_content(acceptance_criteria):
            missing.append("Acceptance Criteria must be filled")
        if not has_any_checklist_item(acceptance_criteria):
            missing.append("Acceptance Criteria must contain checklist items")
        if not has_real_content(validation_plan):
            missing.append("Validation Plan must be filled")
        if not has_any_checklist_item(validation_plan):
            missing.append("Validation Plan must contain checklist items")
        if not has_real_implementation_guidance(implementation_guidance):
            missing.append("Implementation Guidance must be filled")
        elif not has_old_flow_subsection(implementation_guidance):
            missing.append("Implementation Guidance must include an Old Flow Mermaid sequence diagram showing current behavior, or a note explaining why there is no predecessor flow")
        elif not has_mermaid_sequence_subsection(implementation_guidance, "New Flow"):
            missing.append("Implementation Guidance must include a New Flow Mermaid sequence diagram showing target behavior")
        elif not has_implementation_sketch(implementation_guidance):
            missing.append("Implementation Guidance must include an Implementation Sketch with pseudocode or concrete code-shape steps")
        elif not has_guidance_subsection(implementation_guidance, "Code Anchors"):
            missing.append("Implementation Guidance must include Code Anchors naming exact variables, conditions, helpers, or call sites")
        if not has_real_content(implementation_checklist):
            missing.append("Implementation Checklist must be filled")
        if not has_any_checklist_item(implementation_checklist):
            missing.append("Implementation Checklist must contain actionable checklist items")

    if check_state == "planning":
        if not has_real_content(section(text, "Requirement Summary")):
            missing.append("Requirement Summary must be filled")

    if check_state in {"implementation", "review", "quality-check", "approval", "done"}:
        approval = latest_approval(session_id, "planning")
        if not approval:
            missing.append("Planning must be human-approved with `harness approve-planning <session-id>`")
        elif approval["approval_hash"] != planning_snapshot(text):
            missing.append("Planning sections changed after approval; rerun `harness approve-planning <session-id>`")

    if check_state == "implementation" and state in {"implementation", "needs-fix"}:
        if non_harness_changes() and has_unchecked_item(implementation_checklist):
            missing.append("Implementation Checklist has unchecked items while product changes exist")

    if check_state in {"review", "quality-check", "approval", "done"}:
        if not checklist_complete(implementation_checklist):
            missing.append("Implementation Checklist must be fully checked before review")

    if check_state in {"quality-check", "approval", "done"}:
        review = section(text, "Review")
        sync_required_fixes_from_artifact(session_id, text)
        if not has_real_content(subsection(review, "AI Review")):
            missing.append("AI Review must be recorded")
        if not has_real_content(subsection(review, "Human Review")):
            missing.append("Human Review must be recorded")
        if unresolved_required_fixes(session_id):
            missing.append("Review Required Fixes must be resolved before quality-check")
        if not latest_approval(session_id, "review"):
            missing.append("Human review must be approved with `harness approve-review <session-id>`")

    if check_state == "done":
        quality = section(text, "Quality Check")
        if not proof_links_resolve(session_id, subsection(quality, "Proof")):
            missing.append("Quality Check Proof needs at least one checked proof file under proof/")
        approval = latest_approval(session_id, "quality")
        if not approval:
            missing.append("Quality evidence must be approved with `harness approve-quality <session-id>`")
        elif approval["approval_hash"] != quality_snapshot(text):
            missing.append("Quality evidence changed after approval; rerun `harness approve-quality <session-id>`")
        if not has_real_content(section(text, "Final Approval")):
            missing.append("Final Approval must be recorded")

    if check_state in {"quality-check", "approval", "done"} and require_quality_execution:
        validation_plan = section(text, "Validation Plan")
        quality = section(text, "Quality Check")
        if has_unchecked_item(validation_plan):
            missing.append("Validation Plan checklist must be executed and checked off")
        if not has_real_content(subsection(quality, "Commands Run")):
            missing.append("Quality Check Commands Run must record validation commands/results")
        if not proof_links_resolve(session_id, subsection(quality, "Proof")):
            missing.append("Quality Check Proof needs at least one checked proof file under proof/")
        missing.extend(quality_gate_missing(session_id, text))

    if state not in STATES:
        missing.append(f"status must be one of: {', '.join(STATES)}")
    return missing


def validate_planning_approval(session_id: str) -> list[str]:
    text = read_text(artifact_path(session_id))
    approval = latest_approval(session_id, "planning")
    if not approval:
        return ["Planning must be human-approved with `harness approve-planning <session-id>`"]
    if approval["approval_hash"] != planning_snapshot(text):
        return ["Planning sections changed after approval; rerun `harness approve-planning <session-id>`"]
    return []


def skills_dir() -> Path:
    return root() / ".agents" / "skills"


def install_language_skills(force: bool = False) -> list[str]:
    if os.environ.get("HARNESS_SKIP_LANGUAGE_SKILLS") == "1":
        return []
    installed = []
    existing = set()
    sd = skills_dir()
    if sd.exists():
        for entry in sd.iterdir():
            if entry.is_dir() and (entry / "SKILL.md").exists():
                existing.add(entry.name)
    for spec in LANGUAGE_SKILLS:
        name = spec["name"]
        if not force and name in existing:
            continue
        skill_dir = sd / name
        skill_file = skill_dir / "SKILL.md"
        try:
            with urllib.request.urlopen(spec["url"], timeout=30) as resp:
                content = resp.read().decode("utf-8")
        except OSError as exc:
            print(f"warning: failed to fetch skill {name}: {exc}", file=sys.stderr)
            continue
        skill_dir.mkdir(parents=True, exist_ok=True)
        skill_file.write_text(content)
        installed.append(name)
    return installed


def cmd_init(_args: argparse.Namespace) -> None:
    previous_version = read_harness_version()
    harness_dir().mkdir(exist_ok=True)
    sessions_dir().mkdir(parents=True, exist_ok=True)
    agents_dir().mkdir(parents=True, exist_ok=True)
    (harness_dir() / "templates").mkdir(parents=True, exist_ok=True)
    write_new(harness_dir() / "harness.yml", default_config())
    write_new(template_path(), default_template())
    write_new(root() / ".env.example", default_env_example())
    init_db()
    migrate_sqlite()
    write_new(agents_bootstrap_path(), default_agents_bootstrap())
    ensure_claude_symlink()
    for name, content in default_agents().items():
        write_new(agents_dir() / name, content)
    write_new(version_path(), f"{HARNESS_VERSION}\n")
    write_project_map(overwrite=False)
    ensure_gitignore()
    print("initialized harness")
    print_harness_version_change(previous_version)
    installed = install_language_skills()
    if installed:
        print(f"installed language skills: {', '.join(installed)}")


def print_project_map_result(message: str, written: list[Path]) -> None:
    print(message)
    for path in written:
        print(f"- {path.relative_to(root())}")


def cmd_init_project_map(_args: argparse.Namespace) -> None:
    written = write_project_map(overwrite=False)
    if written:
        print_project_map_result("initialized project map", written)
    else:
        print("project map already initialized")


def cmd_sync_project_map(args: argparse.Namespace) -> None:
    if not args.force:
        die("sync-project-map overwrites .harness/project/*.md templates; rerun with --force")
    print_project_map_result("synced project map", write_project_map(overwrite=True))


def print_synced_guardrails(written: list[Path]) -> None:
    print("synced harness guardrails")
    for path in written:
        print(f"- {path.relative_to(root())}")


def sync_target_guardrails(force: bool = False) -> None:
    previous_version = read_harness_version()
    if force or target_guardrails_outdated():
        print_synced_guardrails(overwrite_guardrails())
        print_harness_version_change(previous_version)
        print("target guardrails synced")
        installed = install_language_skills(force=True)
        if installed:
            print(f"installed/refreshed language skills: {', '.join(installed)}")
    else:
        ensure_claude_symlink()
        print("target guardrails current")
        print_harness_version_change(previous_version)


def cmd_sync_guardrails(args: argparse.Namespace) -> None:
    print("sync-guardrails is deprecated; use `harness update`")
    sync_target_guardrails(force=True)


def cmd_upgrade_guardrails(_args: argparse.Namespace) -> None:
    previous_version = read_harness_version()
    print_synced_guardrails(overwrite_guardrails())
    print_harness_version_change(previous_version)


def cmd_update(args: argparse.Namespace) -> None:
    if not args.skip_pull:
        if update_harness_source(harness_source_root()):
            os.execv(sys.executable, [sys.executable, str(Path(__file__).resolve()), "update", "--skip-pull"])
    sync_target_guardrails(force=True)


def validate_requirement_id(value: str, label: str) -> None:
    if not re.match(r"^[A-Za-z0-9][A-Za-z0-9._-]*$", value):
        die(f"{label} must use letters, numbers, dot, underscore, or dash")


def parse_story_arg(raw: str, index: int) -> dict[str, str]:
    value = raw.strip()
    if not value:
        die("--story must not be empty")
    if ":" in value:
        story_id, title = value.split(":", 1)
        story_id = story_id.strip()
        title = title.strip() or story_id
    else:
        if re.match(r"^[A-Za-z0-9][A-Za-z0-9._-]*$", value):
            story_id = value
            title = value
        else:
            story_id = f"story-{index:03d}"
            title = value
    validate_requirement_id(story_id, "story id")
    return {"story_id": story_id, "title": title}


def planning_mode(force_single: bool, force_split: bool) -> str:
    if force_single and force_split:
        die("choose only one of --single-session or --split-stories")
    if force_split:
        return "child-session"
    return "single-session"


def default_epic_plan(epic_id: str, mode: str, stories: list[dict[str, str]]) -> str:
    story_rows = "\n".join(
        f"| {story['story_id']} | {story['title']} | draft |"
        for story in stories
    )
    return f"""# Epic Plan: {epic_id}

## Planning Mode Decision

Mode: {mode}

## Story Registry

| Story | Title | Status |
|---|---|---|
{story_rows}

## Requirement Summary

TBD

## Cross-Story Dependencies

TBD

## Open Questions

- [ ] TBD
"""


def default_synthesis(epic_id: str, stories: list[dict[str, str]]) -> str:
    queue_rows = "\n".join(
        f"| {index} | {story['story_id']} | draft | TBD |"
        for index, story in enumerate(stories, start=1)
    )
    return f"""# Epic Synthesis: {epic_id}

## Implementation Queue

| Order | Story | Status | Reason |
|---|---|---|---|
{queue_rows}

## Shared Decisions

TBD

## Blockers

- [ ] TBD
"""


def stringify_metadata(metadata: dict[str, object]) -> dict[str, str]:
    return {key: str(value) for key, value in metadata.items() if key != "dependencies"}


def default_story_plan(epic_id: str, story: dict[str, str], mode: str, metadata: dict[str, object]) -> str:
    body = f"""# Story Plan: {story['story_id']}

## Source Epic

{epic_id}

## Title

{story['title']}

## Target Repo

TBD

## Planning Mode

{mode}

## Behavior / Acceptance Criteria

- [ ] TBD

## Out of Scope

TBD

## Dependencies

- [ ] TBD

## Implementation Plan

TBD

## Test Plan

- [ ] TBD

## Open Questions

- [ ] TBD
"""
    return dump_frontmatter(stringify_metadata(metadata), body)


def story_metadata(epic_id: str, story: dict[str, str], index: int) -> dict[str, object]:
    timestamp = now()
    return {
        "session_id": story["story_id"],
        "status": "draft",
        "planning_approved": "false",
        "planning_approved_by": "",
        "planning_approved_at": "",
        "planning_approved_hash": "",
        "review_approved": "false",
        "review_approved_by": "",
        "review_approved_at": "",
        "quality_approved": "false",
        "quality_approved_by": "",
        "quality_approved_at": "",
        "recovery_attempts": "0",
        "created_at": timestamp,
        "updated_at": timestamp,
        "parent_session_id": epic_id,
        "epic_id": epic_id,
        "story_id": story["story_id"],
        "title": story["title"],
        "planning_session_id": "",
        "target_repo": "",
        "plan_md": f"children/{story['story_id']}/plan.md",
        "plan_html": f"children/{story['story_id']}/plan.html",
        "dependencies": [],
        "implementation_order": index,
    }


def write_json(path: Path, data: dict[str, object]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(data, indent=2, sort_keys=True) + "\n")


def load_story_metadata(path: Path) -> dict[str, object]:
    try:
        data = json.loads(read_text(path))
    except json.JSONDecodeError as exc:
        die(f"invalid story metadata {path}: {exc}")
    if not isinstance(data, dict):
        die(f"invalid story metadata {path}: expected object")
    return data


def find_story_metadata(story_id: str) -> tuple[Path, dict[str, object]]:
    matches = []
    for path in sessions_dir().glob(f"*/children/{story_id}/metadata.json"):
        matches.append((path, load_story_metadata(path)))
    if not matches:
        die(f"story not found: {story_id}")
    if len(matches) > 1:
        locations = ", ".join(str(path.parent) for path, _data in matches)
        die(f"story id is ambiguous across epics: {story_id} ({locations})")
    return matches[0]


def metadata_by_story_id(story_id: str) -> dict[str, object] | None:
    for path in sessions_dir().glob(f"*/children/{story_id}/metadata.json"):
        return load_story_metadata(path)
    return None


def render_story_plan(epic_id: str, story: dict[str, str], metadata: dict[str, object]) -> Path:
    string_metadata = stringify_metadata(metadata)
    return render_markdown_document(
        story_plan_path(epic_id, story["story_id"]),
        story_plan_html_path(epic_id, story["story_id"]),
        f"Story Plan: {story['story_id']}",
        "Harness Story Plan",
        string_metadata,
        "Session Metadata",
    )


def update_story_plan_metadata(plan_path: Path, updates: dict[str, object]) -> None:
    metadata, body = parse_frontmatter(read_text(plan_path))
    for key, value in updates.items():
        metadata[key] = str(value)
    plan_path.write_text(dump_frontmatter(metadata, body))


def story_plan_to_session_artifact(
    session_id: str,
    story_id: str,
    story_title: str,
    epic_id: str,
    coordinator_repo: Path,
    target_repo: Path,
    plan_text: str,
    created: str,
) -> str:
    behavior = section(plan_text, "Behavior / Acceptance Criteria").strip() or "- [ ] TBD"
    tests = section(plan_text, "Test Plan").strip() or "- [ ] TBD"
    target_repo_section = section(plan_text, "Target Repo").strip()
    implementation_plan = section(plan_text, "Implementation Plan").strip() or "TBD"
    dependencies = section(plan_text, "Dependencies").strip() or "- [ ] TBD"
    out_of_scope = section(plan_text, "Out of Scope").strip() or "TBD"
    open_questions = section(plan_text, "Open Questions").strip() or "- [ ] TBD"
    source_plan = coordinator_repo / ".harness" / "sessions" / epic_id / "children" / story_id / "plan.md"
    repo_note = target_repo_section if target_repo_section and target_repo_section != "TBD" else str(target_repo)
    body = f"""# Harness Session: {session_id}

## Requirement Summary

Repo-local implementation session for child story `{story_id}` from parent epic `{epic_id}`.

Target repo: `{repo_note}`
Coordinator repo: `{coordinator_repo}`
Source child plan: `{source_plan}`

{story_title}

## Acceptance Criteria

{behavior}

## Validation Plan

{tests}

## Implementation Guidance

This session is scoped to `{repo_note}` only. Do not edit sibling repositories from this session; cross-repo ordering and handoff notes stay in the parent epic.

### Dependencies

{dependencies}

### Out of Scope

{out_of_scope}

### Old Flow

```mermaid
sequenceDiagram
    participant Caller
    participant Existing_Repo_Surface
    participant Existing_Service_Or_Gateway
    Caller->>Existing_Repo_Surface: current repo-owned request or event
    Existing_Repo_Surface->>Existing_Service_Or_Gateway: current behavior
    Existing_Service_Or_Gateway-->>Existing_Repo_Surface: current result
    Existing_Repo_Surface-->>Caller: current response or side effect
```

### New Flow

```mermaid
sequenceDiagram
    participant Caller
    participant Repo_Local_Surface
    participant Repo_Local_Service
    participant Downstream_Contract
    Caller->>Repo_Local_Surface: scoped request or event
    Repo_Local_Surface->>Repo_Local_Service: apply child-story behavior
    alt feature enabled / eligible
        Repo_Local_Service->>Downstream_Contract: call repo-owned dependency contract
        Downstream_Contract-->>Repo_Local_Service: result
    else feature disabled / ineligible
        Repo_Local_Service-->>Repo_Local_Surface: preserve existing behavior
    end
    Repo_Local_Surface-->>Caller: response or non-blocking side effect
```

### Implementation Sketch

{implementation_plan}

### Code Anchors

Use the concrete file/function anchors listed in the implementation sketch above. Re-verify every anchor against the current `{repo_note}` checkout before editing because the source child plan may have been produced from RFC-cited locations.

### Open Questions

{open_questions}

## Implementation Checklist

{behavior}

## Planning Approval

TBD

## Review

### AI Review

TBD

### Human Review

TBD

### Required Fixes

None.

## Quality Check

### Commands Run

TBD

### Proof

TBD

## Final Approval

TBD
"""
    metadata = {
        "session_id": session_id,
        "status": "planning",
        "planning_approved": "false",
        "planning_approved_by": "",
        "planning_approved_at": "",
        "planning_approved_hash": "",
        "review_approved": "false",
        "review_approved_by": "",
        "review_approved_at": "",
        "quality_approved": "false",
        "quality_approved_by": "",
        "quality_approved_at": "",
        "recovery_attempts": "0",
        "created_at": created,
        "updated_at": created,
        "parent_session_id": epic_id,
        "story_id": story_id,
        "coordinator_repo": str(coordinator_repo),
        "target_repo": str(target_repo),
    }
    return dump_frontmatter(metadata, body)


def path_uri(path: Path) -> str:
    return path.resolve().as_uri()


def story_repo_label(target_repo: str) -> str:
    if not target_repo:
        return "_not linked_"
    return f"[{Path(target_repo).name}]({path_uri(Path(target_repo))})"


def story_session_label(target_repo: str, planning_session_id: str) -> str:
    if not target_repo or not planning_session_id:
        return "_not linked_"
    artifact_html = Path(target_repo) / ".harness" / "sessions" / planning_session_id / "artifact.html"
    if artifact_html.exists():
        return f"[{planning_session_id}]({path_uri(artifact_html)})"
    return planning_session_id


def sorted_epic_stories(epic_base: Path) -> list[dict[str, str]]:
    children_dir = epic_base / "children"
    if not children_dir.exists():
        return []
    metadata_items = sorted(
        (load_story_metadata(path) for path in children_dir.glob("*/metadata.json")),
        key=lambda item: int(item.get("implementation_order", 0)),
    )
    return [
        {"story_id": str(item["story_id"]), "title": str(item.get("title", item["story_id"]))}
        for item in metadata_items
    ]


def update_story_link(
    metadata_file: Path,
    data: dict[str, object],
    plan_md: Path,
    story_id: str,
    session_id: str,
    target_repo: Path,
    status: str,
    updated_at: str,
) -> None:
    epic_base = metadata_file.parents[2]
    epic_id = str(data.get("epic_id", epic_base.name))
    story_title = str(data.get("title", story_id))
    updates = {
        "planning_session_id": session_id,
        "target_repo": str(target_repo),
        "status": status,
        "updated_at": updated_at,
    }
    data.update(updates)
    write_json(metadata_file, data)
    update_story_plan_metadata(plan_md, updates)
    render_story_plan(epic_id, {"story_id": story_id, "title": story_title}, data)
    render_epic_index(epic_id, "child-session", sorted_epic_stories(epic_base))


def render_epic_index(epic_id: str, mode: str, stories: list[dict[str, str]]) -> Path:
    rows = []
    for story in stories:
        story_id = story["story_id"]
        story_html = f"children/{story_id}/plan.html"
        metadata_file = story_metadata_path(epic_id, story_id)
        status = "draft"
        target_repo = ""
        planning_session_id = ""
        if metadata_file.exists():
            data = load_story_metadata(metadata_file)
            status = str(data.get("status", "draft"))
            target_repo = str(data.get("target_repo", ""))
            planning_session_id = str(data.get("planning_session_id", ""))
        rows.append(
            f"| [{story_id}]({story_html}) | {story['title']} | {status} | "
            f"{story_repo_label(target_repo)} | {story_session_label(target_repo, planning_session_id)} |"
        )
    story_table = "\n".join(rows) if rows else "| _single-session_ | See epic plan | draft | _n/a_ | _n/a_ |"
    content = f"""# Epic Planning Index: {epic_id}

## Mode

{mode}

## Artifacts

- [Epic plan](epic-plan.md)
- [Synthesis](synthesis.md)

## Stories

| Child Plan | Title | Status | Repo | Repo Session |
|---|---|---|---|---|
{story_table}
"""
    return render_markdown_content_document(
        content,
        epic_index_path(epic_id),
        f"Epic Planning Index: {epic_id}",
        "Harness Epic Index",
        {"epic_id": epic_id, "mode": mode, "story_count": str(len(stories))},
    )


def write_story_artifacts(epic_id: str, stories: list[dict[str, str]], mode: str, force: bool = False) -> None:
    for index, story in enumerate(stories, start=1):
        plan_path = story_plan_path(epic_id, story["story_id"])
        metadata_path = story_metadata_path(epic_id, story["story_id"])
        if (plan_path.exists() or metadata_path.exists()) and not force:
            die(f"story already exists: {story['story_id']}; rerun with --force to overwrite child artifacts")
        metadata = story_metadata(epic_id, story, index)
        plan_path.parent.mkdir(parents=True, exist_ok=True)
        plan_path.write_text(default_story_plan(epic_id, story, mode, metadata))
        write_json(metadata_path, metadata)
        render_story_plan(epic_id, story, metadata)


def cmd_plan_epic(args: argparse.Namespace) -> None:
    validate_requirement_id(args.epic_id, "epic id")
    raw_stories = args.story or ["story-001:TBD"]
    stories = [parse_story_arg(raw, index) for index, raw in enumerate(raw_stories, start=1)]
    story_ids = [story["story_id"] for story in stories]
    if len(story_ids) != len(set(story_ids)):
        die("duplicate story id in --story arguments")
    mode = planning_mode(args.single_session, args.split_stories)
    base = epic_dir(args.epic_id)
    if base.exists() and not args.force:
        die(f"epic already exists: {args.epic_id}; rerun with --force to overwrite planning artifacts")
    base.mkdir(parents=True, exist_ok=True)
    epic_plan_path(args.epic_id).write_text(default_epic_plan(args.epic_id, mode, stories))
    epic_synthesis_path(args.epic_id).write_text(default_synthesis(args.epic_id, stories))
    if mode == "child-session":
        write_story_artifacts(args.epic_id, stories, mode, force=args.force)
    render_epic_index(args.epic_id, mode, stories if mode == "child-session" else [])
    print(f"planned epic: {args.epic_id}")
    print(f"mode: {mode}")
    print(f"epic plan: {epic_plan_path(args.epic_id)}")
    print(f"synthesis: {epic_synthesis_path(args.epic_id)}")
    print(f"index: {epic_index_path(args.epic_id)}")
    if mode == "child-session":
        for story in stories:
            print(f"story: {story['story_id']} {story_plan_path(args.epic_id, story['story_id'])}")


def cmd_split_session(args: argparse.Namespace) -> None:
    validate_requirement_id(args.session_id, "session id")
    state = current_state(args.session_id)
    if state != "planning":
        die(f"split-session requires session state 'planning', current state is '{state}'")
    if not args.story:
        die("split-session requires at least one --story")
    stories = [parse_story_arg(raw, index) for index, raw in enumerate(args.story, start=1)]
    story_ids = [story["story_id"] for story in stories]
    if len(story_ids) != len(set(story_ids)):
        die("duplicate story id in --story arguments")
    if not epic_plan_path(args.session_id).exists() or args.force:
        epic_plan_path(args.session_id).write_text(default_epic_plan(args.session_id, "child-session", stories))
    if not epic_synthesis_path(args.session_id).exists() or args.force:
        epic_synthesis_path(args.session_id).write_text(default_synthesis(args.session_id, stories))
    write_story_artifacts(args.session_id, stories, "child-session", force=args.force)
    render_epic_index(args.session_id, "child-session", stories)
    render_artifact_html(args.session_id)
    print(f"split session: {args.session_id}")
    print("mode: child-session")
    print(f"parent artifact: {artifact_path(args.session_id)}")
    print(f"index: {epic_index_path(args.session_id)}")
    for story in stories:
        print(f"story: {story['story_id']} {story_plan_path(args.session_id, story['story_id'])}")


def cmd_start_story(args: argparse.Namespace) -> None:
    validate_requirement_id(args.story_id, "story id")
    metadata_file, data = find_story_metadata(args.story_id)
    epic_base = metadata_file.parents[2]
    epic_id = str(data.get("epic_id", epic_base.name))
    plan_md = epic_base / str(data.get("plan_md", f"children/{args.story_id}/plan.md"))
    if not plan_md.exists():
        die(f"story plan missing: {plan_md}")

    coordinator_repo = root().resolve()
    target_repo = Path(args.repo).expanduser().resolve() if args.repo else coordinator_repo
    if not target_repo.exists() or not target_repo.is_dir():
        die(f"target repo does not exist: {target_repo}")
    target_harness = target_repo / ".harness"
    if not target_harness.exists():
        die(f"target repo is not harness-initialized: {target_repo}; run `harness init` there first")

    created = now()
    session_id = args.session_id or date_prefixed_session_id(args.story_id, created)
    validate_requirement_id(session_id, "session id")
    target_artifact = target_harness / "sessions" / session_id / "artifact.md"
    if target_artifact.exists() and not args.force:
        die(f"target story session already exists: {target_artifact}; rerun with --force to overwrite")

    plan_text = read_text(plan_md)
    story_title = str(data.get("title", args.story_id))
    artifact_text = story_plan_to_session_artifact(
        session_id,
        args.story_id,
        story_title,
        epic_id,
        coordinator_repo,
        target_repo,
        plan_text,
        created,
    )

    old_cwd = Path.cwd()
    try:
        os.chdir(target_repo)
        if not db_path().exists():
            init_db()
        migrate_sqlite()
        target_artifact.parent.mkdir(parents=True, exist_ok=True)
        proof_dir(session_id).mkdir(parents=True, exist_ok=True)
        target_artifact.write_text(artifact_text)
        with db() as conn:
            conn.execute("DELETE FROM sessions WHERE session_id = ?", (session_id,))
        insert_session(session_id, "planning", created)
        render_artifact_html(session_id)
    finally:
        os.chdir(old_cwd)

    update_story_link(metadata_file, data, plan_md, args.story_id, session_id, target_repo, "planning", created)
    print(f"started story session: {session_id}")
    print(f"story: {args.story_id}")
    print(f"target repo: {target_repo}")
    print(f"artifact: {target_artifact}")
    print(f"state: planning")


def cmd_link_story(args: argparse.Namespace) -> None:
    validate_requirement_id(args.story_id, "story id")
    validate_requirement_id(args.session_id, "session id")
    metadata_file, data = find_story_metadata(args.story_id)
    epic_base = metadata_file.parents[2]
    plan_md = epic_base / str(data.get("plan_md", f"children/{args.story_id}/plan.md"))
    if not plan_md.exists():
        die(f"story plan missing: {plan_md}")

    target_repo = Path(args.repo).expanduser().resolve()
    if not target_repo.exists() or not target_repo.is_dir():
        die(f"target repo does not exist: {target_repo}")
    target_harness = target_repo / ".harness"
    if not target_harness.exists():
        die(f"target repo is not harness-initialized: {target_repo}; run `harness init` there first")
    target_artifact = target_harness / "sessions" / args.session_id / "artifact.md"
    if not target_artifact.exists():
        die(f"target story session artifact does not exist: {target_artifact}")

    target_meta, _body = parse_frontmatter(read_text(target_artifact))
    status = target_meta.get("status", "planning") or "planning"
    old_cwd = Path.cwd()
    try:
        os.chdir(target_repo)
        render_artifact_html(args.session_id)
    finally:
        os.chdir(old_cwd)
    updated_at = now()
    update_story_link(metadata_file, data, plan_md, args.story_id, args.session_id, target_repo, status, updated_at)
    print(f"linked story session: {args.session_id}")
    print(f"story: {args.story_id}")
    print(f"target repo: {target_repo}")
    print(f"artifact: {target_artifact}")
    print(f"state: {status}")


def cmd_implement(args: argparse.Namespace) -> None:
    validate_requirement_id(args.story_id, "story id")
    metadata_file, data = find_story_metadata(args.story_id)
    status = str(data.get("status", "draft"))
    if status != "ready":
        die(f"story {args.story_id} is not ready for implementation: status={status}")
    planning_session_id = str(data.get("planning_session_id", ""))
    if not planning_session_id:
        die(
            f"story {args.story_id} has no linked repo-local planning session; "
            f"run `harness start-story {args.story_id} --repo <repo-path>` first"
        )
    dependencies = data.get("dependencies", [])
    if not isinstance(dependencies, list):
        die(f"story {args.story_id} has invalid dependencies in {metadata_file}")
    blocked = []
    for dependency in dependencies:
        dependency_data = metadata_by_story_id(str(dependency))
        if not dependency_data:
            blocked.append(f"{dependency}: missing")
        elif dependency_data.get("status") != "done":
            blocked.append(f"{dependency}: status={dependency_data.get('status', 'draft')}")
    if blocked:
        print("implementation blocked")
        for item in blocked:
            print(f"- dependency {item}")
        raise SystemExit(1)
    epic_base = metadata_file.parents[2]
    plan_md = epic_base / str(data.get("plan_md", f"children/{args.story_id}/plan.md"))
    plan_html = epic_base / str(data.get("plan_html", f"children/{args.story_id}/plan.html"))
    if not plan_md.exists():
        die(f"story plan missing: {plan_md}")
    print(f"implementation target: {args.story_id}")
    print(f"epic: {data.get('epic_id', epic_base.name)}")
    print(f"status: {status}")
    print(f"plan: {plan_md}")
    print(f"html: {plan_html}")
    print(f"planning_session_id: {planning_session_id}")
    print(f"target_repo: {data.get('target_repo', '')}")


def cmd_start(args: argparse.Namespace) -> None:
    validate_requirement_id(args.session_id, "session title")
    warn_if_guardrails_outdated()
    if not template_path().exists():
        cmd_init(argparse.Namespace())
    if not db_path().exists():
        init_db()
    created = now()
    session_id = date_prefixed_session_id(args.session_id, created)
    if artifact_path(session_id).exists():
        die(f"session already exists: {session_id}")
    content = read_text(template_path())
    replacements = {
        "{{SESSION_ID}}": session_id,
        "{{CREATED_AT}}": created,
        "{{UPDATED_AT}}": created,
    }
    for old, new in replacements.items():
        content = content.replace(old, new)
    content = re.sub(r'^linear_issue_(key|url):.*\n', "", content, flags=re.MULTILINE)
    proof_dir(session_id).mkdir(parents=True, exist_ok=True)
    artifact_path(session_id).write_text(content)
    insert_session(session_id, "start", created)
    render_artifact_html(session_id)
    print(f"created session: {session_id}")
    print(f"artifact: {artifact_path(session_id)}")
    print(f"html artifact: {artifact_html_path(session_id)}")
    print(f"proof: {proof_dir(session_id)}")


def cmd_list(_args: argparse.Namespace) -> None:
    with db() as conn:
        rows = conn.execute(
            """
            SELECT session_id, state, artifact_path, updated_at
            FROM sessions
            ORDER BY updated_at DESC, session_id ASC
            """
        ).fetchall()
    if not rows:
        print("no sessions")
        return
    print("session_id\tstate\tupdated_at\trecovery_attempts\tartifact")
    for row in rows:
        path = Path(row["artifact_path"])
        attempts = artifact_recovery_attempts(path)
        print(f"{row['session_id']}\t{row['state']}\t{row['updated_at']}\t{attempts}\t{path}")


def print_history_section(title: str, lines: list[str]) -> None:
    print(title)
    if lines:
        for line in lines:
            print(f"- {line}")
    else:
        print("- none")


def cmd_history(args: argparse.Namespace) -> None:
    current_state(args.session_id)
    with db() as conn:
        transitions = conn.execute(
            """
            SELECT created_at, from_state, to_state, result, reason
            FROM transitions
            WHERE session_id = ?
            ORDER BY id ASC
            """,
            (args.session_id,),
        ).fetchall()
        approvals = conn.execute(
            """
            SELECT created_at, approval_type, approver
            FROM approvals
            WHERE session_id = ?
            ORDER BY id ASC
            """,
            (args.session_id,),
        ).fetchall()
        review_passes = conn.execute(
            """
            SELECT created_at, content
            FROM review_passes
            WHERE session_id = ?
            ORDER BY id ASC
            """,
            (args.session_id,),
        ).fetchall()
        required_fixes = conn.execute(
            """
            SELECT created_at, resolved_at, description, resolved
            FROM required_fixes
            WHERE session_id = ?
            ORDER BY id ASC
            """,
            (args.session_id,),
        ).fetchall()
        proofs = conn.execute(
            """
            SELECT created_at, path, proof_type
            FROM proofs
            WHERE session_id = ?
            ORDER BY id ASC
            """,
            (args.session_id,),
        ).fetchall()

    print(f"Session history: {args.session_id}")
    print_history_section(
        "Transitions",
        [
            f"{row['created_at']} {row['from_state']} -> {row['to_state']} {row['result']}"
            + (f" reason: {row['reason']}" if row["reason"] else "")
            for row in transitions
        ],
    )
    print_history_section(
        "Approvals",
        [f"{row['created_at']} {row['approval_type']} by {row['approver']}" for row in approvals],
    )
    print_history_section(
        "Review Passes",
        [f"{row['created_at']} {one_line_summary(row['content'])}" for row in review_passes],
    )
    print_history_section(
        "Required Fixes",
        [
            f"{row['created_at']} {'resolved' if row['resolved'] else 'open'}"
            + (f" resolved_at: {row['resolved_at']}" if row["resolved_at"] else "")
            + f" {row['description']}"
            for row in required_fixes
        ],
    )
    print_history_section(
        "Proofs",
        [
            f"{row['created_at']} {row['path']}"
            + (f" type: {row['proof_type']}" if row["proof_type"] else "")
            for row in proofs
        ],
    )


def cmd_status(args: argparse.Namespace) -> None:
    state = current_state(args.session_id)
    missing = validate_requirements(args.session_id)
    html_path = render_artifact_html(args.session_id)
    print(f"Session: {args.session_id}")
    print(f"State: {state}")
    print(f"Artifact: {artifact_path(args.session_id)}")
    if html_path:
        print(f"HTML artifact: {html_path}")
    print(f"State store: {db_path()}")
    print(f"Common guardrail: {agents_dir() / 'common.md'}")
    print(f"State guardrail: {agents_dir() / (state + '.md')}")
    print(f"Next action: {next_action_for_state(state)}")
    print(f"Recovery attempts: {recovery_attempts(args.session_id)}/{MAX_RECOVERY_ATTEMPTS}")
    if state in {"implementation", "needs-fix"}:
        print("Edit gate: allowed")
    else:
        print(f"Edit gate: blocked in {state}")
    changes = non_harness_changes()
    if changes and state not in {"implementation", "needs-fix"}:
        print("Guardrail violation: non-harness changes exist outside implementation/needs-fix")
        for path in changes[:20]:
            print(f"- {path}")
        if len(changes) > 20:
            print(f"- ... {len(changes) - 20} more")
    if missing:
        print("Missing:")
        for item in missing:
            print(f"- {item}")
    else:
        print("Missing: none")


def cmd_next(args: argparse.Namespace) -> None:
    state = current_state(args.session_id)
    missing = validate_requirements(args.session_id)
    commands = next_followup_commands(args.session_id, state)
    print(f"Session: {args.session_id}")
    print(f"State: {state}")
    print(f"Next action: {next_action_for_state(state)}")
    print(f"Recovery attempts: {recovery_attempts(args.session_id)}/{MAX_RECOVERY_ATTEMPTS}")
    if state in {"implementation", "needs-fix"}:
        print("Edit gate: allowed")
    else:
        print(f"Edit gate: blocked in {state}")
    if missing:
        print("Blocked by:")
        for item in missing:
            print(f"- {item}")
        print("After resolving blockers, run:")
    else:
        print("Blocked by: none")
        print("Run:")
    if commands:
        for command in commands:
            print(f"- {command}")
    else:
        print("- no commands required")


def cmd_validate(args: argparse.Namespace) -> None:
    target = getattr(args, "target", None)
    missing = validate_requirements(args.session_id, target)
    if missing:
        print("invalid")
        for item in missing:
            print(f"- {item}")
        raise SystemExit(1)
    render_artifact_html(args.session_id)
    print("valid")
    maybe_auto_serve_planning(args.session_id)


def cmd_preflight_edit(args: argparse.Namespace) -> None:
    state = current_state(args.session_id)
    if state not in {"implementation", "needs-fix"}:
        die(f"product code edits blocked while session is in '{state}'. Complete planning and transition to implementation first.")
    if state == "needs-fix":
        missing = validate_planning_approval(args.session_id)
    else:
        missing = validate_requirements(args.session_id, "implementation")
    if missing:
        print("edit preflight blocked")
        for item in missing:
            print(f"- {item}")
        raise SystemExit(1)
    print("edit preflight allowed")


def cmd_approve_planning(args: argparse.Namespace) -> None:
    approver = default_approval_name(args.by)
    state = current_state(args.session_id)
    if state != "planning":
        die(f"planning approval requires session state 'planning', current state is '{state}'")
    missing = validate_requirements(args.session_id, "planning")
    if missing:
        print("planning approval blocked")
        for item in missing:
            print(f"- {item}")
        raise SystemExit(1)
    path = artifact_path(args.session_id)
    text = read_text(path)
    approval = f"Approved by {approver} at {now()}."
    text = check_section_items(text, "Acceptance Criteria")
    if "## Planning Approval\n\nTBD" in text:
        text = text.replace("## Planning Approval\n\nTBD", f"## Planning Approval\n\n{approval}")
    path.write_text(text)
    update_artifact_meta(
        args.session_id,
        {
            "planning_approved": "true",
            "planning_approved_by": approver,
            "planning_approved_at": now(),
            "planning_approved_hash": planning_snapshot(read_text(path)),
        },
    )
    insert_approval(args.session_id, "planning", approver, planning_snapshot(read_text(path)))
    print(f"planning approved by {approver}")


def cmd_approve_review(args: argparse.Namespace) -> None:
    approver = default_approval_name(args.by)
    state = current_state(args.session_id)
    if state != "review":
        die(f"review approval requires session state 'review', current state is '{state}'")
    missing = validate_requirements(args.session_id, "review")
    if missing:
        print("review approval blocked")
        for item in missing:
            print(f"- {item}")
        raise SystemExit(1)
    path = artifact_path(args.session_id)
    text = read_text(path)
    approval = f"Approved by {approver} at {now()}."
    review_text = section(text, "Review")
    human_review = subsection(review_text, "Human Review")
    if not has_real_content(human_review):
        text = text.replace("### Human Review\n\nTBD", f"### Human Review\n\n{approval}")
        path.write_text(text)
    update_artifact_meta(
        args.session_id,
        {
            "review_approved": "true",
            "review_approved_by": approver,
            "review_approved_at": now(),
        },
    )
    insert_approval(args.session_id, "review", approver, "")
    print(f"review approved by {approver}")


