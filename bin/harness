def proof_dir(session_id: str) -> Path:
    return sessions_dir() / session_id / "proof"


def agents_bootstrap_path() -> Path:
    sample = root() / "AGENTS_SAMPLE.md"
    if sample.exists():
        return sample
    return root() / "AGENTS.md"


def db_path() -> Path:
    return harness_dir() / "harness.db"


def version_path() -> Path:
    return harness_dir() / "version"


def now() -> str:
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat()


JAKARTA_TZ = dt.timezone(dt.timedelta(hours=7), "GMT+7")


def format_display_timestamp(value: str) -> str:
    raw = value.strip()
    if not raw:
        return raw
    try:
        parsed = dt.datetime.fromisoformat(raw.replace("Z", "+00:00"))
    except ValueError:
        return value
    if parsed.tzinfo is None:
        parsed = parsed.replace(tzinfo=dt.timezone.utc)
    local = parsed.astimezone(JAKARTA_TZ)
    return f"{local:%A, %d %B %Y %H:%M:%S} GMT+7"


def display_metadata_value(key: str, value: str) -> str:
    if key.endswith("_at"):
        return format_display_timestamp(value)
    return value


def die(message: str, code: int = 1) -> None:
    print(f"error: {message}", file=sys.stderr)
    raise SystemExit(code)


def read_text(path: Path) -> str:
    try:
        return path.read_text()
    except FileNotFoundError:
        die(f"missing file: {path}")


def write_new(path: Path, content: str) -> bool:
    if path.exists():
        return False
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)
    return True


def write_harness_version() -> None:
    harness_dir().mkdir(exist_ok=True)
    version_path().write_text(f"{HARNESS_VERSION}\n")


def read_harness_version() -> str | None:
    try:
        return version_path().read_text().strip()
    except FileNotFoundError:
        return None


def version_parts(version: str) -> tuple[int | str, ...]:
    parts: list[int | str] = []
    for part in re.split(r"[.-]", version):
        if part.isdigit():
            parts.append(int(part))
        elif part:
            parts.append(part)
    return tuple(parts)


def target_guardrails_outdated() -> bool:
    if not harness_dir().exists():
        return False
    current = read_harness_version()
    if not current:
        return True
    return version_parts(current) < version_parts(HARNESS_VERSION)


def warn_if_guardrails_outdated() -> None:
    if target_guardrails_outdated():
        print("warning: target guardrails are outdated; run harness update", file=sys.stderr)


def version_label(version: str | None) -> str:
    return version if version else "none"


def print_harness_version_change(previous: str | None) -> None:
    print(f"harness version: {version_label(previous)} -> {HARNESS_VERSION}")


def ensure_gitignore() -> None:
    path = root() / ".gitignore"
    required = [".env", ".harness/harness.db"]
    if path.exists():
        lines = path.read_text().splitlines()
        missing = [line for line in required if line not in lines]
        if missing:
            with path.open("a") as fh:
                if lines and lines[-1] != "":
                    fh.write("\n")
                for line in missing:
                    fh.write(f"{line}\n")
    else:
        path.write_text("".join(f"{line}\n" for line in required))


def default_approval_name(explicit: str | None) -> str:
    if explicit:
        return explicit
    result = subprocess.run(
        ["whoami"],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    name = result.stdout.strip() if result.returncode == 0 else ""
    if name:
        return name
    return os.environ.get("USER") or os.environ.get("USERNAME") or "unknown"


