ANNOTATION_CLIENT_JS = """
(function () {
  var annotations = window.__ANNOTATIONS__ || [];
  var commentBtn = null, popover = null;

  function api(method, path, body) {
    return fetch(path, {
      method: method,
      headers: { "Content-Type": "application/json" },
      body: body ? JSON.stringify(body) : undefined
    }).then(function (r) { return r.ok ? r.json() : Promise.reject(r); });
  }

  function contextFor(range, sectionEl) {
    var pre = document.createRange();
    pre.selectNodeContents(sectionEl);
    pre.setEnd(range.startContainer, range.startOffset);
    var post = document.createRange();
    post.selectNodeContents(sectionEl);
    post.setStart(range.endContainer, range.endOffset);
    return { prefix: pre.toString().slice(-40), suffix: post.toString().slice(0, 40) };
  }

  function clearFloating() {
    if (commentBtn) { commentBtn.remove(); commentBtn = null; }
    if (popover) { popover.remove(); popover = null; }
  }

  document.addEventListener("mouseup", function (e) {
    if ((commentBtn && commentBtn.contains(e.target)) || (popover && popover.contains(e.target))) return;
    setTimeout(function () {
      var sel = window.getSelection();
      if (!sel || sel.isCollapsed) { clearFloating(); return; }
      var text = sel.toString().trim();
      if (!text) { clearFloating(); return; }
      var range = sel.getRangeAt(0);
      var sectionEl = range.startContainer.parentElement
        ? range.startContainer.parentElement.closest(".section-body, .artifact-intro")
        : null;
      var detailsEl = range.startContainer.parentElement
        ? range.startContainer.parentElement.closest("[data-section]")
        : null;
      if (!sectionEl) { clearFloating(); return; }
      var rect = range.getBoundingClientRect();
      clearFloating();
      commentBtn = document.createElement("button");
      commentBtn.className = "hx-comment-btn";
      commentBtn.textContent = "💬 Comment";
      commentBtn.style.left = (window.scrollX + rect.left + rect.width / 2) + "px";
      commentBtn.style.top = (window.scrollY + rect.bottom) + "px";
      commentBtn.addEventListener("click", function () {
        openPopover(text, contextFor(range, sectionEl), detailsEl ? detailsEl.getAttribute("data-section") : "", rect);
      });
      document.body.appendChild(commentBtn);
    }, 10);
  });

  function openPopover(quote, ctx, section, rect) {
    if (popover) popover.remove();
    popover = document.createElement("div");
    popover.className = "hx-popover";
    popover.style.left = (window.scrollX + rect.left) + "px";
    popover.style.top = (window.scrollY + rect.bottom + 34) + "px";
    var q = document.createElement("div");
    q.className = "hx-quote";
    q.textContent = "“" + (quote.length > 90 ? quote.slice(0, 90) + "…" : quote) + "”";
    var ta = document.createElement("textarea");
    ta.placeholder = "Leave a comment for the agent…";
    var actions = document.createElement("div");
    actions.className = "hx-actions";
    var cancel = document.createElement("button");
    cancel.textContent = "Cancel";
    cancel.addEventListener("click", clearFloating);
    var save = document.createElement("button");
    save.textContent = "Save";
    save.addEventListener("click", function () {
      var comment = ta.value.trim();
      if (!comment) { ta.focus(); return; }
      api("POST", "/annotations", {
        quote: quote, comment: comment, section: section, prefix: ctx.prefix, suffix: ctx.suffix
      }).then(function (ann) {
        annotations.push(ann);
        clearFloating();
        window.getSelection().removeAllRanges();
        renderPanel();
        highlightAll();
      });
    });
    actions.appendChild(cancel); actions.appendChild(save);
    popover.appendChild(q); popover.appendChild(ta); popover.appendChild(actions);
    document.body.appendChild(popover);
    ta.focus();
  }

  function renderPanel() {
    var panel = document.getElementById("hx-panel");
    if (!panel) {
      panel = document.createElement("aside");
      panel.className = "hx-panel"; panel.id = "hx-panel";
      document.body.appendChild(panel);
      document.body.classList.add("hx-has-panel");
    }
    var open = annotations.filter(function (a) { return a.status !== "addressed"; }).length;
    var head = "<h3>Comments — " + open + " open</h3>";
    if (!annotations.length) { panel.innerHTML = head + "<p style='color:#756f66'>Select text in the plan to add a comment.</p>"; return; }
    panel.innerHTML = head + annotations.map(function (a) {
      var cls = a.status === "addressed" ? "hx-card addressed" : "hx-card";
      return "<div class='" + cls + "' data-id='" + a.id + "'>"
        + "<span class='hx-badge'>" + (a.status === "addressed" ? "addressed" : "open") + "</span>"
        + "<blockquote>" + escapeHtml(a.quote) + "</blockquote>"
        + "<div class='hx-note'>" + escapeHtml(a.comment) + "</div>"
        + "<button class='hx-del' data-del='" + a.id + "'>Delete</button>"
        + "</div>";
    }).join("");
    panel.querySelectorAll("[data-del]").forEach(function (btn) {
      btn.addEventListener("click", function () {
        var id = btn.getAttribute("data-del");
        api("DELETE", "/annotations/" + id).then(function () {
          annotations = annotations.filter(function (a) { return a.id !== id; });
          renderPanel(); highlightAll();
        });
      });
    });
  }

  function escapeHtml(s) {
    return String(s).replace(/[&<>"]/g, function (c) {
      return { "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c];
    });
  }

  function highlightAll() {
    document.querySelectorAll("mark.hx-mark").forEach(function (m) {
      var parent = m.parentNode; parent.replaceChild(document.createTextNode(m.textContent), m); parent.normalize();
    });
    annotations.forEach(function (a) {
      var scope = a.section ? document.querySelector("[data-section='" + a.section + "'] .section-body") : document;
      if (!scope) scope = document;
      markFirst(scope, a.quote);
    });
  }

  function markFirst(scope, quote) {
    if (!quote) return;
    var walker = document.createTreeWalker(scope, NodeFilter.SHOW_TEXT, null);
    var node;
    while ((node = walker.nextNode())) {
      var idx = node.nodeValue.indexOf(quote);
      if (idx === -1) continue;
      var range = document.createRange();
      range.setStart(node, idx); range.setEnd(node, idx + quote.length);
      var mark = document.createElement("mark"); mark.className = "hx-mark";
      try { range.surroundContents(mark); } catch (e) { }
      return;
    }
  }

  function buildToolbar() {
    var bar = document.createElement("div");
    bar.className = "hx-toolbar";
    bar.innerHTML = "<span>📝 Annotate plan</span><span class='hx-spacer'></span>";
    var complete = document.createElement("button");
    complete.className = "hx-complete";
    complete.textContent = "Complete";
    complete.addEventListener("click", function () {
      api("POST", "/shutdown", {}).catch(function () { }).then(showDone);
      setTimeout(showDone, 400);
    });
    bar.appendChild(complete);
    document.body.appendChild(bar);
  }

  function showDone() {
    if (document.querySelector(".hx-done-overlay")) return;
    var o = document.createElement("div");
    o.className = "hx-done-overlay";
    o.textContent = "Comments saved. You can close this tab and ask the agent to check your inline comments.";
    document.body.appendChild(o);
  }

  buildToolbar();
  renderPanel();
  highlightAll();
})();
"""


def build_annotation_page(session_id: str) -> str:
    html_path = render_artifact_html(session_id)
    if html_path is None:
        return "<!doctype html><meta charset=utf-8><p>No artifact for this session.</p>"
    document = html_path.read_text()
    payload = json.dumps(load_annotations(session_id))
    injection = (
        "<style>" + ANNOTATION_CLIENT_CSS + "</style>"
        + "<script>window.__ANNOTATIONS__ = " + payload + ";</script>"
        + "<script>" + ANNOTATION_CLIENT_JS + "</script>"
    )
    if "</body>" in document:
        return document.replace("</body>", injection + "</body>", 1)
    return document + injection


def make_annotation_handler(session_id: str):
    class AnnotationHandler(BaseHTTPRequestHandler):
        def log_message(self, *_args) -> None:  # keep the CLI output quiet
            pass

        def _send(self, code: int, body: str, content_type: str = "application/json") -> None:
            data = body.encode("utf-8")
            self.send_response(code)
            self.send_header("Content-Type", content_type)
            self.send_header("Content-Length", str(len(data)))
            self.end_headers()
            self.wfile.write(data)

        def _read_json(self) -> dict:
            length = int(self.headers.get("Content-Length", 0) or 0)
            if not length:
                return {}
            try:
                return json.loads(self.rfile.read(length).decode("utf-8"))
            except (ValueError, UnicodeDecodeError):
                return {}

        def do_GET(self) -> None:  # noqa: N802
            if self.path == "/":
                self._send(200, build_annotation_page(session_id), "text/html; charset=utf-8")
            elif self.path == "/annotations":
                self._send(200, json.dumps(load_annotations(session_id)))
            else:
                self._send(404, json.dumps({"error": "not found"}))

        def do_POST(self) -> None:  # noqa: N802
            if self.path == "/annotations":
                try:
                    annotation = add_annotation(session_id, self._read_json())
                except ValueError as exc:
                    self._send(400, json.dumps({"error": str(exc)}))
                    return
                self._send(201, json.dumps(annotation))
            elif self.path.startswith("/annotations/"):
                annotation_id = self.path.rsplit("/", 1)[-1]
                updated = update_annotation(session_id, annotation_id, self._read_json())
                if updated is None:
                    self._send(404, json.dumps({"error": "not found"}))
                else:
                    self._send(200, json.dumps(updated))
            elif self.path == "/shutdown":
                self._send(200, json.dumps({"ok": True}))
                threading.Thread(target=self.server.shutdown, daemon=True).start()
            else:
                self._send(404, json.dumps({"error": "not found"}))

        def do_DELETE(self) -> None:  # noqa: N802
            if self.path.startswith("/annotations/"):
                annotation_id = self.path.rsplit("/", 1)[-1]
                ok = delete_annotation(session_id, annotation_id)
                self._send(200 if ok else 404, json.dumps({"ok": ok}))
            else:
                self._send(404, json.dumps({"error": "not found"}))

    return AnnotationHandler


def serve_state_path(session_id: str) -> Path:
    return sessions_dir() / session_id / ".serve.json"


def running_serve(session_id: str) -> dict | None:
    """Return metadata for a live background serve process, or None."""
    path = serve_state_path(session_id)
    if not path.exists():
        return None
    try:
        data = json.loads(path.read_text())
    except (json.JSONDecodeError, OSError):
        return None
    pid = data.get("pid")
    if not pid:
        return None
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        path.unlink(missing_ok=True)
        return None
    except PermissionError:
        return data  # process exists but is not ours
    except OSError:
        return None
    return data


def start_background_serve(session_id: str) -> dict | None:
    """Fork a detached annotation server. Returns its metadata, or None if unsupported."""
    if not hasattr(os, "fork"):
        return None
    server = ThreadingHTTPServer(("127.0.0.1", 0), make_annotation_handler(session_id))
    port = server.server_address[1]
    url = f"http://127.0.0.1:{port}/"
    pid = os.fork()
    if pid > 0:
        # Parent: hand ownership of the socket to the child and record the process.
        server.socket.close()
        state = {"pid": pid, "port": port, "url": url, "started_at": now()}
        serve_state_path(session_id).parent.mkdir(parents=True, exist_ok=True)
        serve_state_path(session_id).write_text(json.dumps(state) + "\n")
        return state
    # Child: detach from the controlling terminal and its stdio so the caller
    # (and any capturing pipe) returns immediately, then serve until shutdown.
    try:
        os.setsid()
    except OSError:
        pass
    devnull = os.open(os.devnull, os.O_RDWR)
    for fd in (0, 1, 2):
        os.dup2(devnull, fd)
    try:
        server.serve_forever()
    except Exception:
        pass
    finally:
        server.server_close()
        serve_state_path(session_id).unlink(missing_ok=True)
    os._exit(0)


def cmd_serve(args: argparse.Namespace) -> None:
    current_state(args.session_id)  # validates the session exists
    if not artifact_path(args.session_id).exists():
        die(f"artifact not found for session: {args.session_id}")
    if getattr(args, "detach", False):
        existing = running_serve(args.session_id)
        if existing:
            print(f"Already serving {args.session_id} at {existing['url']} (pid {existing['pid']})")
            _open_browser(existing["url"])
            return
        state = start_background_serve(args.session_id)
        if state is None:
            print("Background serve is not supported on this platform; serving in the foreground.")
        else:
            print(f"Serving annotation view for {args.session_id} at {state['url']} (background pid {state['pid']})")
            print('Add inline comments in the browser, then click "Complete" to stop the server.')
            _open_browser(state["url"])
            return
    server = ThreadingHTTPServer(("127.0.0.1", 0), make_annotation_handler(args.session_id))
    port = server.server_address[1]
    url = f"http://127.0.0.1:{port}/"
    print(f"Serving annotation view for {args.session_id} at {url}")
    print('Add inline comments in the browser, then click "Complete" (or press Ctrl-C) to stop.')
    _open_browser(url)
    try:
        server.serve_forever()
    except KeyboardInterrupt:
        pass
    finally:
        server.server_close()
    open_count = sum(1 for a in load_annotations(args.session_id) if a.get("status") != "addressed")
    print(f"Stopped. {open_count} open annotation(s) saved to {annotations_path(args.session_id)}")


def _open_browser(url: str) -> None:
    try:
        webbrowser.open(url)
    except Exception:
        pass


def maybe_auto_serve_planning(session_id: str) -> None:
    """After a passing planning validation, open the plan for inline review in the background."""
    if os.environ.get("HARNESS_AUTO_SERVE", "1").strip().lower() in {"0", "false", "no", "off", ""}:
        return
    if not hasattr(os, "fork"):
        return
    try:
        if current_state(session_id) != "planning":
            return
    except SystemExit:
        return
    existing = running_serve(session_id)
    if existing:
        print(f"Plan review already open at {existing['url']} — add comments, then ask me to check them.")
        return
    state = start_background_serve(session_id)
    if not state:
        return
    print(f"Opened the plan for inline review at {state['url']} (background pid {state['pid']}).")
    print("Add inline comments in your browser, then ask me to check your inline comments.")
    _open_browser(state["url"])


def artifact_sections(body: str) -> list[dict]:
    """Split artifact markdown into level-2 sections, mirroring render_artifact_body slugs."""
    sections: list[dict] = []
    used_slugs: dict[str, int] = {}
    current: dict | None = None
    for offset, line in enumerate(body.splitlines()):
        match = re.match(r"^##\s+(.*)$", line)
        if match:
            title = match.group(1).strip()
            base_slug = slugify(title)
            count = used_slugs.get(base_slug, 0)
            used_slugs[base_slug] = count + 1
            slug = base_slug if count == 0 else f"{base_slug}-{count + 1}"
            current = {"title": title, "slug": slug, "lines": []}
            sections.append(current)
        elif current is not None:
            current["lines"].append((offset + 1, line))
    return sections


def locate_quote(section: dict, quote: str) -> tuple[int | None, str]:
    quote = quote.strip()
    if not quote:
        return None, ""
    for lineno, line in section["lines"]:
        if quote in line:
            return lineno, line.strip()
    text = "\n".join(line for _, line in section["lines"])
    if quote in text:
        return section["lines"][0][0] if section["lines"] else None, "(matches across multiple lines)"
    normalized = re.sub(r"\s+", " ", text)
    if re.sub(r"\s+", " ", quote) in normalized:
        return section["lines"][0][0] if section["lines"] else None, "(matches with normalized whitespace)"
    return None, ""


def cmd_annotations(args: argparse.Namespace) -> None:
    session_id = args.session_id
    if args.resolve:
        updated = update_annotation(session_id, args.resolve, {"status": "addressed"})
        if updated is None:
            die(f"annotation not found: {args.resolve}")
        print(f"marked addressed: {args.resolve}")
        return
    path = artifact_path(session_id)
    if not path.exists():
        die(f"artifact not found for session: {session_id}")
    annotations = load_annotations(session_id)
    if not args.all:
        annotations = [a for a in annotations if a.get("status") != "addressed"]
    if not annotations:
        print("No annotations." if args.all else "No open annotations.")
        return
    body = parse_frontmatter(read_text(path))[1]
    sections = {section["slug"]: section for section in artifact_sections(body)}
    print(f"{len(annotations)} annotation(s) for {session_id}:\n")
    for annotation in annotations:
        section = sections.get(annotation.get("section", ""))
        print(f"[{annotation['id']}] ({annotation.get('status', 'open')})")
        if section:
            lineno, snippet = locate_quote(section, annotation.get("quote", ""))
            print(f"  section: ## {section['title']}")
            if lineno:
                print(f"  location: {path.name}:{lineno}  {snippet}".rstrip())
            else:
                print(f"  location: stale — text not found; search section '## {section['title']}'")
        else:
            print(f"  section: (unknown slug '{annotation.get('section', '')}')")
        print(f"  quote: {annotation.get('quote', '')!r}")
        print(f"  comment: {annotation.get('comment', '')}")
        print()


def cmd_migrate_sqlite(_args: argparse.Namespace) -> None:
    migrated = migrate_sqlite()
    print(f"migrated sessions: {migrated}")


def config_states() -> list[str]:
    path = harness_dir() / "harness.yml"
    if not path.exists():
        return []
    states = []
    in_states = False
    for line in path.read_text().splitlines():
        stripped = line.strip()
        if stripped == "states:":
            in_states = True
            continue
        if in_states:
            if not line.startswith("  "):
                break
            if stripped.startswith("- "):
                states.append(stripped[2:].strip())
    return states


def doctor_static_issues() -> list[str]:
    issues = []
    generated = default_agents()
    expected_agents = {f"{state}.md" for state in STATES}
    expected_agents.add("common.md")
    generated_agents = set(generated)
    for name in sorted(expected_agents - generated_agents):
        issues.append(f"generated guardrails missing {name} from default_agents()")
    for name in sorted(generated_agents - expected_agents):
        issues.append(f"generated guardrails include unexpected file {name}")
    for name, content in sorted(generated.items()):
        path = agents_dir() / name
        if not path.exists():
            issues.append(f"missing guardrail file: {path}")
        elif path.read_text() != content:
            issues.append(f"guardrail drift: {path} differs from default_agents()")
    bootstrap = agents_bootstrap_path()
    if not bootstrap.exists():
        issues.append(f"missing bootstrap file: {bootstrap}")
    elif bootstrap.read_text() != default_agents_bootstrap():
        issues.append(f"bootstrap drift: {bootstrap} differs from default_agents_bootstrap()")
    states = config_states()
    if states and states != STATES:
        issues.append(f"config states differ from CLI STATES: {states}")
    elif not states and (harness_dir() / "harness.yml").exists():
        issues.append("config states missing from .harness/harness.yml")
    gitignore = root() / ".gitignore"
    if not gitignore.exists():
        issues.append("missing .gitignore")
    else:
        lines = set(gitignore.read_text().splitlines())
        for required in [".env", ".harness/harness.db"]:
            if required not in lines:
                issues.append(f".gitignore missing {required}")
    if template_path().exists():
        template = template_path().read_text()
        for heading in [
            "Requirement Summary",
            "Acceptance Criteria",
            "Validation Plan",
            "Implementation Guidance",
            "Implementation Checklist",
            "Review",
            "Quality Check",
            "Final Approval",
        ]:
            if f"## {heading}" not in template:
                issues.append(f"session template missing ## {heading}")
    elif harness_dir().exists():
        issues.append(f"missing session template: {template_path()}")
    return issues


def cmd_doctor(_args: argparse.Namespace) -> None:
    issues = doctor_static_issues()
    if not db_path().exists():
        if harness_dir().exists() and template_path().exists() and agents_dir().exists():
            init_db()
            migrated = migrate_sqlite()
            print(f"initialized missing SQLite state store: {db_path()}")
            if migrated:
                print(f"migrated sessions: {migrated}")
        else:
            issues.append(f"missing SQLite state store: {db_path()}")
    if not issues:
        try:
            with db() as conn:
                sessions = conn.execute("SELECT session_id, state, artifact_path FROM sessions ORDER BY session_id").fetchall()
                for row in sessions:
                    path = Path(row["artifact_path"])
                    if not path.exists():
                        issues.append(f"{row['session_id']}: artifact missing at {path}")
                        continue
                    data, _ = parse_frontmatter(read_text(path))
                    if data.get("status") and data.get("status") != row["state"]:
                        issues.append(f"{row['session_id']}: artifact status {data.get('status')} differs from SQLite state {row['state']}")
                proofs = conn.execute("SELECT session_id, path FROM proofs ORDER BY id").fetchall()
                for row in proofs:
                    if not Path(row["path"]).exists():
                        issues.append(f"{row['session_id']}: proof missing at {row['path']}")
        except sqlite3.Error as exc:
            issues.append(f"SQLite error: {exc}")
    if issues:
        print("doctor failed")
        for issue in issues:
            print(f"- {issue}")
        raise SystemExit(1)
    print("doctor ok")


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="harness")
    sub = parser.add_subparsers(dest="command", required=True)

    init_p = sub.add_parser("init")
    init_p.set_defaults(func=cmd_init)

    init_project_map_p = sub.add_parser("init-project-map")
    init_project_map_p.set_defaults(func=cmd_init_project_map)

    sync_project_map_p = sub.add_parser("sync-project-map")
    sync_project_map_p.add_argument("--force", action="store_true")
    sync_project_map_p.set_defaults(func=cmd_sync_project_map)

    upgrade_p = sub.add_parser("upgrade-guardrails")
    upgrade_p.set_defaults(func=cmd_upgrade_guardrails)

    sync_guardrails_p = sub.add_parser("sync-guardrails")
    sync_guardrails_p.add_argument("--force", action="store_true")
    sync_guardrails_p.set_defaults(func=cmd_sync_guardrails)

    update_p = sub.add_parser("update")
    update_p.add_argument("--skip-pull", action="store_true")
    update_p.set_defaults(func=cmd_update)

    start_p = sub.add_parser("start")
    start_p.add_argument("session_id")
    start_p.set_defaults(func=cmd_start)

    plan_epic_p = sub.add_parser("plan-epic")
    plan_epic_p.add_argument("epic_id")
    plan_epic_p.add_argument("--story", action="append", default=[])
    plan_epic_p.add_argument("--single-session", action="store_true")
    plan_epic_p.add_argument("--split-stories", action="store_true")
    plan_epic_p.add_argument("--force", action="store_true")
    plan_epic_p.set_defaults(func=cmd_plan_epic)

    split_session_p = sub.add_parser("split-session")
    split_session_p.add_argument("session_id")
    split_session_p.add_argument("--story", action="append", default=[])
    split_session_p.add_argument("--force", action="store_true")
    split_session_p.set_defaults(func=cmd_split_session)

    start_story_p = sub.add_parser("start-story")
    start_story_p.add_argument("story_id")
    start_story_p.add_argument("--repo")
    start_story_p.add_argument("--session-id")
    start_story_p.add_argument("--force", action="store_true")
    start_story_p.set_defaults(func=cmd_start_story)

    link_story_p = sub.add_parser("link-story")
    link_story_p.add_argument("story_id")
    link_story_p.add_argument("--repo", required=True)
    link_story_p.add_argument("--session-id", required=True)
    link_story_p.set_defaults(func=cmd_link_story)

    implement_p = sub.add_parser("implement")
    implement_p.add_argument("story_id")
    implement_p.set_defaults(func=cmd_implement)

    migrate_p = sub.add_parser("migrate-sqlite")
    migrate_p.set_defaults(func=cmd_migrate_sqlite)

    doctor_p = sub.add_parser("doctor")
    doctor_p.set_defaults(func=cmd_doctor)

    list_p = sub.add_parser("list")
    list_p.set_defaults(func=cmd_list)

    history_p = sub.add_parser("history")
    history_p.add_argument("session_id")
    history_p.set_defaults(func=cmd_history)

    status_p = sub.add_parser("status")
    status_p.add_argument("session_id")
    status_p.set_defaults(func=cmd_status)

    next_p = sub.add_parser("next")
    next_p.add_argument("session_id")
    next_p.set_defaults(func=cmd_next)

    validate_p = sub.add_parser("validate")
    validate_p.add_argument("session_id")
    validate_p.add_argument("--target")
    validate_p.set_defaults(func=cmd_validate)

    preflight_p = sub.add_parser("preflight-edit")
    preflight_p.add_argument("session_id")
    preflight_p.set_defaults(func=cmd_preflight_edit)

    approve_p = sub.add_parser("approve-planning")
    approve_p.add_argument("session_id")
    approve_p.add_argument("--by")
    approve_p.set_defaults(func=cmd_approve_planning)

    approve_review_p = sub.add_parser("approve-review")
    approve_review_p.add_argument("session_id")
    approve_review_p.add_argument("--by")
    approve_review_p.set_defaults(func=cmd_approve_review)

    approve_quality_p = sub.add_parser("approve-quality")
    approve_quality_p.add_argument("session_id")
    approve_quality_p.add_argument("--by")
    approve_quality_p.set_defaults(func=cmd_approve_quality)

    record_review_p = sub.add_parser("record-review")
    record_review_p.add_argument("session_id")
    record_review_p.add_argument("--ai")
    record_review_p.add_argument("--file")
    record_review_p.add_argument("--required-fix", action="append", default=[])
    record_review_p.set_defaults(func=cmd_record_review)

    transition_p = sub.add_parser("transition")
    transition_p.add_argument("session_id")
    transition_p.add_argument("state")
    transition_p.set_defaults(func=cmd_transition)

    recover_p = sub.add_parser("recover")
    recover_p.add_argument("session_id")
    recover_p.add_argument("--reason", required=True)
    recover_p.set_defaults(func=cmd_recover)

    proof_p = sub.add_parser("attach-proof")
    proof_p.add_argument("session_id")
    proof_p.add_argument("file")
    proof_p.set_defaults(func=cmd_attach_proof)

    serve_p = sub.add_parser("serve")
    serve_p.add_argument("session_id")
    serve_p.add_argument("-d", "--detach", action="store_true", help="run the server in the background and return immediately")
    serve_p.set_defaults(func=cmd_serve)

    annotations_p = sub.add_parser("annotations")
    annotations_p.add_argument("session_id")
    annotations_p.add_argument("--all", action="store_true", help="include annotations already marked addressed")
    annotations_p.add_argument("--resolve", metavar="ANNOTATION_ID", help="mark the given annotation id as addressed")
    annotations_p.set_defaults(func=cmd_annotations)

    return parser


def main() -> None:
    parser = build_parser()
    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
