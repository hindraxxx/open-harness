MAX_RECOVERY_ATTEMPTS = 3
STATES = ["start", "planning", "implementation", "review", "needs-fix", "quality-check", "approval", "blocked", "done"]
TRANSITIONS = {
    "start": {"planning"},
    "planning": {"implementation"},
    "implementation": {"review", "needs-fix"},
    "review": {"quality-check", "needs-fix"},
    "needs-fix": {"implementation", "blocked"},
    "quality-check": {"approval", "needs-fix"},
    "approval": {"done", "needs-fix"},
    "blocked": {"planning", "implementation", "quality-check", "approval", "done"},
    "done": set(),
}


def root() -> Path:
    return Path.cwd()


def harness_dir() -> Path:
    return root() / ".harness"


def sessions_dir() -> Path:
    return harness_dir() / "sessions"


def agents_dir() -> Path:
    return harness_dir() / "agents"


def project_map_dir() -> Path:
    return harness_dir() / "project"


def template_path() -> Path:
    return harness_dir() / "templates" / "session.md"


def artifact_path(session_id: str) -> Path:
    return sessions_dir() / session_id / "artifact.md"


def artifact_html_path(session_id: str) -> Path:
    return artifact_path(session_id).with_suffix(".html")


def proof_dir(session_id: str) -> Path:
    return sessions_dir() / session_id / "proof"


def agents_bootstrap_path() -> Path:
    sample = root() / "AGENTS_SAMPLE.md"
    if sample.exists():
        return sample
    return root() / "AGENTS.md"


def db_path() -> Path:
    return harness_dir() / "harness.db"


def now() -> str:
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat()


def die(message: str, code: int = 1) -> None:
    print(f"error: {message}", file=sys.stderr)
    raise SystemExit(code)


def read_text(path: Path) -> str:
    try:
        return path.read_text()
    except FileNotFoundError:
        die(f"missing file: {path}")


def write_new(path: Path, content: str) -> bool:
    if path.exists():
        return False
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)
    return True


def ensure_gitignore() -> None:
    path = root() / ".gitignore"
    required = [".env", ".harness/harness.db"]
    if path.exists():
        lines = path.read_text().splitlines()
        missing = [line for line in required if line not in lines]
        if missing:
            with path.open("a") as fh:
                if lines and lines[-1] != "":
                    fh.write("\n")
                for line in missing:
                    fh.write(f"{line}\n")
    else:
        path.write_text("".join(f"{line}\n" for line in required))


def default_approval_name(explicit: str | None) -> str:
    if explicit:
        return explicit
    result = subprocess.run(
        ["whoami"],
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        check=False,
    )
    name = result.stdout.strip() if result.returncode == 0 else ""
    if name:
        return name
    return os.environ.get("USER") or os.environ.get("USERNAME") or "unknown"


def default_config() -> str:
    return """version: 1
artifact: artifact.md
proof_dir: proof
states:
  - start
  - planning
  - implementation
  - review
  - needs-fix
  - quality-check
  - approval
  - blocked
  - done
initial_state: start
quality_gate:
  required_proof: auto
"""


