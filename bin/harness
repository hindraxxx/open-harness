h1, h2, h3, h4 {{
  color: var(--ink);
  line-height: 1.18;
  margin: 1.35em 0 0.58em;
}}
h1 {{
  font-size: clamp(2rem, 4vw, 3.1rem);
  letter-spacing: 0;
  margin: 0;
